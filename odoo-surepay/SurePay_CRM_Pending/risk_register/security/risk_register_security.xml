<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        
        <!-- Risk Management Module Category -->
        <record id="module_category_risk_management" model="ir.module.category">
            <field name="name">Risk Management</field>
            <field name="description">Helps you manage risks and compliance</field>
            <field name="sequence">15</field>
        </record>
        
        <!-- Risk User Group -->
        <record id="group_risk_user" model="res.groups">
            <field name="name">Risk User</field>
            <field name="category_id" ref="module_category_risk_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">User can manage risks in own department</field>
        </record>
        
        <!-- Risk Manager Group -->
        <record id="group_risk_manager" model="res.groups">
            <field name="name">Risk Manager</field>
            <field name="category_id" ref="module_category_risk_management"/>
            <field name="implied_ids" eval="[(4, ref('group_risk_user'))]"/>
            <field name="comment">Manager can manage all risks</field>
        </record>
        
        <!-- Risk Admin Group -->
        <record id="group_risk_admin" model="res.groups">
            <field name="name">Risk Administrator</field>
            <field name="category_id" ref="module_category_risk_management"/>
            <field name="implied_ids" eval="[(4, ref('group_risk_manager'))]"/>
            <field name="comment">Administrator has full access and configuration rights</field>
        </record>
        
        <!-- Record Rules for Department Access -->
        <record id="risk_register_rule_user" model="ir.rule">
            <field name="name">Risk Register User Department Rule</field>
            <field name="model_id" ref="model_risk_register"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_risk_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        
        <record id="risk_register_rule_manager" model="ir.rule">
            <field name="name">Risk Register Manager Rule</field>
            <field name="model_id" ref="model_risk_register"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_risk_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        
        <record id="risk_register_rule_admin" model="ir.rule">
            <field name="name">Risk Register Admin Rule</field>
            <field name="model_id" ref="model_risk_register"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_risk_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        
        
    </data>
</odoo>
