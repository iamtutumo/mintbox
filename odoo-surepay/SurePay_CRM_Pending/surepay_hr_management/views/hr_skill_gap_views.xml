<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Skill Gap Tree View -->
        <record id="view_hr_skill_gap_tree" model="ir.ui.view">
            <field name="name">hr.skill.gap.tree</field>
            <field name="model">hr.skill.gap</field>
            <field name="arch" type="xml">
                <tree string="Skill Gaps" decoration-info="status=='open'" 
                      decoration-warning="status=='in_progress'" 
                      decoration-success="status=='closed'">
                    <field name="employee_id"/>
                    <field name="gap_title"/>
                    <field name="priority"/>
                    <field name="status"/>
                    <field name="identified_by"/>
                    <field name="date_identified"/>
                    <field name="department_id"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </tree>
            </field>
        </record>

        <!-- Skill Gap Form View -->
        <record id="view_hr_skill_gap_form" model="ir.ui.view">
            <field name="name">hr.skill.gap.form</field>
            <field name="model">hr.skill.gap</field>
            <field name="arch" type="xml">
                <form string="Skill Gap">
                    <header>
                        <button name="action_set_in_progress" string="Start Progress" 
                                type="object" class="btn-primary" 
                                invisible="status != 'open'"/>
                        <button name="action_set_closed" string="Mark as Resolved" 
                                type="object" class="btn-success" 
                                invisible="status != 'in_progress'"/>
                        <button name="action_reopen" string="Reopen" 
                                type="object" class="btn-secondary" 
                                invisible="status != 'closed'"/>
                        <field name="status" widget="statusbar" statusbar_visible="open,in_progress"/>
                    </header>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_send_notification" type="object" class="oe_stat_button" icon="fa-envelope" invisible="notification_sent == True">
                            <field name="notification_sent" widget="boolean_toggle" string="Send Notification"/>
                        </button>
                    </div>
                    <sheet>
                        <group>
                            <group>
                                <field name="employee_id"/>
                                <field name="department_id"/>
                                <field name="job_id"/>
                                <field name="manager_id"/>
                                <field name="identified_by"/>
                                <field name="date_identified"/>
                            </group>
                            <group>
                                <field name="priority"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Description">
                                <field name="gap_title" placeholder="Brief title of the skill gap"/>
                                <field name="gap_description" placeholder="Detailed description of the skill gap"/>
                            </page>
                            <page string="Resolution">
                                <field name="resolution_notes" placeholder="Notes about how this gap was resolved"/>
                                <field name="date_resolved"/>
                                <field name="resolved_by"/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Skill Gap Kanban View -->
        <record id="view_hr_skill_gap_kanban" model="ir.ui.view">
            <field name="name">hr.skill.gap.kanban</field>
            <field name="model">hr.skill.gap</field>
            <field name="arch" type="xml">
                <kanban class="o_hr_skill_gap_kanban" default_group_by="status">
                    <field name="status"/>
                    <field name="employee_id"/>
                    <field name="gap_title"/>
                    <field name="priority"/>
                    <field name="date_identified"/>
                    <field name="department_id"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_card oe_kanban_global_click {{record.priority.raw_value == 'high' ? 'oe_kanban_card_red' : record.priority.raw_value == 'medium' ? 'oe_kanban_card_orange' : ''}}">
                                <div class="oe_kanban_content">
                                    <div class="oe_kanban_details">
                                        <strong class="o_kanban_record_title">
                                            <field name="gap_title"/>
                                        </strong>
                                        <div class="o_kanban_tags_section">
                                            <span class="badge badge-pill badge-info">
                                                <field name="employee_id" display="full_name"/>
                                            </span>
                                            <span t-attf-class="badge badge-pill #{record.priority.raw_value == 'high' ? 'badge-danger' : record.priority.raw_value == 'medium' ? 'badge-warning' : 'badge-secondary'}">
                                                <field name="priority"/>
                                            </span>
                                            <span t-attf-class="badge badge-pill #{record.status.raw_value == 'open' ? 'badge-info' : record.status.raw_value == 'in_progress' ? 'badge-warning' : 'badge-success'}">
                                                <field name="status"/>
                                            </span>
                                        </div>
                                        <div class="text-muted small">
                                            <field name="department_id" display="name"/>
                                        </div>
                                        <div class="text-muted small">
                                            <i class="fa fa-calendar"/> <field name="date_identified"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="oe_kanban_manage_button_section">
                                    <a class="btn btn-primary btn-sm" type="object" name="action_set_in_progress" t-if="record.status.raw_value == 'open'">
                                        Start Progress
                                    </a>
                                    <a class="btn btn-success btn-sm" type="object" name="action_set_closed" t-if="record.status.raw_value == 'in_progress'">
                                        Resolve
                                    </a>
                                    <a class="btn btn-secondary btn-sm" type="object" name="action_reopen" t-if="record.status.raw_value == 'closed'">
                                        Reopen
                                    </a>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Skill Gap Search View -->
        <record id="view_hr_skill_gap_search" model="ir.ui.view">
            <field name="name">hr.skill.gap.search</field>
            <field name="model">hr.skill.gap</field>
            <field name="arch" type="xml">
                <search string="Skill Gaps">
                    <field name="employee_id"/>
                    <field name="gap_title"/>
                    <field name="gap_description"/>
                    <field name="department_id"/>
                    <field name="status"/>
                    <field name="priority"/>
                    <field name="identified_by"/>
                    <separator/>
                    <filter name="my_gaps" string="My Identified Gaps" 
                            domain="[('identified_by', '=', uid)]"/>
                    <filter name="my_employee_gaps" string="My Employee Gaps" 
                            domain="[('employee_id.parent_id.user_id', '=', uid)]"/>
                    <filter name="my_department_gaps" string="My Department Gaps" 
                            domain="[('department_id.manager_id.user_id', '=', uid)]"/>
                    <separator/>
                    <filter name="status_open" string="Open" 
                            domain="[('status', '=', 'open')]"/>
                    <filter name="status_in_progress" string="In Progress" 
                            domain="[('status', '=', 'in_progress')]"/>
                    <filter name="status_closed" string="Closed" 
                            domain="[('status', '=', 'closed')]"/>
                    <separator/>
                    <filter name="priority_high" string="High Priority" 
                            domain="[('priority', '=', 'high')]"/>
                    <filter name="priority_medium" string="Medium Priority" 
                            domain="[('priority', '=', 'medium')]"/>
                    <filter name="priority_low" string="Low Priority" 
                            domain="[('priority', '=', 'low')]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter name="group_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                        <filter name="group_department" string="Department" context="{'group_by': 'department_id'}"/>
                        <filter name="group_priority" string="Priority" context="{'group_by': 'priority'}"/>
                        <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                        <filter name="group_identified_by" string="Identified By" context="{'group_by': 'identified_by'}"/>
                        <filter name="group_date_identified" string="Date Identified" context="{'group_by': 'date_identified'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Skill Gap Action -->
        <record id="action_hr_skill_gap" model="ir.actions.act_window">
            <field name="name">Skill Gaps</field>
            <field name="res_model">hr.skill.gap</field>
            <field name="view_mode">tree,kanban,form</field>
            <field name="context">{'search_default_my_employee_gaps': 1, 'search_default_status_open': 1, 'search_default_status_in_progress': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first skill gap
                </p>
                <p>
                    Track and manage skill gaps across your organization. 
                    Identify areas where employees need development and create action plans to address them.
                </p>
            </field>
        </record>

        <!-- Skill Gap Pivot View -->
        <record id="view_hr_skill_gap_pivot" model="ir.ui.view">
            <field name="name">hr.skill.gap.pivot</field>
            <field name="model">hr.skill.gap</field>
            <field name="arch" type="xml">
                <pivot string="Skill Gap Analysis">
                    <field name="employee_id" type="row"/>
                    <field name="department_id" type="col"/>
                    <field name="status" type="col"/>
                </pivot>
            </field>
        </record>

        <!-- Skill Gap Graph View -->
        <record id="view_hr_skill_gap_graph" model="ir.ui.view">
            <field name="name">hr.skill.gap.graph</field>
            <field name="model">hr.skill.gap</field>
            <field name="arch" type="xml">
                <graph string="Skill Gap Analysis">
                    <field name="department_id" type="row"/>
                    <field name="status" type="col"/>
                </graph>
            </field>
        </record>

        <!-- Skill Gap Analysis Action -->
        <record id="action_hr_skill_gap_analysis" model="ir.actions.act_window">
            <field name="name">Skill Gap Analysis</field>
            <field name="res_model">hr.skill.gap</field>
            <field name="view_mode">pivot,graph</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Analyze skill gaps across your organization
                </p>
                <p>
                    Use pivot and graph views to analyze skill gaps by department, status, and priority.
                </p>
            </field>
        </record>

    </data>
</odoo>
