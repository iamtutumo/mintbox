<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Employee Analytics Form View -->
        <record id="hr_employee_analytics_view_form" model="ir.ui.view">
            <field name="name">hr.employee.analytics.form</field>
            <field name="model">hr.employee.analytics</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="department_id"/>
                                <field name="date"/>
                                <field name="month"/>
                                <field name="year"/>
                            </group>
                            <group>
                                <field name="employee_count"/>
                                <field name="active_employee_count"/>
                                <field name="on_probation_count"/>
                                <field name="contract_expiring_count"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="disciplinary_action_count"/>
                                <field name="skill_gap_count"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        
        <!-- Employee Analytics Tree View -->
        <record id="hr_employee_analytics_view_tree" model="ir.ui.view">
            <field name="name">hr.employee.analytics.tree</field>
            <field name="model">hr.employee.analytics</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="department_id"/>
                    <field name="employee_count"/>
                    <field name="active_employee_count"/>
                    <field name="on_probation_count"/>
                    <field name="contract_expiring_count"/>
                    <field name="disciplinary_action_count"/>
                    <field name="skill_gap_count"/>
                    <field name="date"/>
                    <field name="month"/>
                    <field name="year"/>
                </tree>
            </field>
        </record>
        
        <!-- Employee Analytics Pivot View -->
        <record id="hr_employee_analytics_view_pivot" model="ir.ui.view">
            <field name="name">hr.employee.analytics.pivot</field>
            <field name="model">hr.employee.analytics</field>
            <field name="arch" type="xml">
                <pivot string="Employee Analytics">
                    <field name="department_id" type="row"/>
                    <field name="employee_count" type="measure"/>
                    <field name="active_employee_count" type="measure"/>
                    <field name="on_probation_count" type="measure"/>
                    <field name="contract_expiring_count" type="measure"/>
                    <field name="disciplinary_action_count" type="measure"/>
                    <field name="skill_gap_count" type="measure"/>
                </pivot>
            </field>
        </record>
        
        <!-- Employee Analytics Graph View -->
        <record id="hr_employee_analytics_view_graph" model="ir.ui.view">
            <field name="name">hr.employee.analytics.graph</field>
            <field name="model">hr.employee.analytics</field>
            <field name="arch" type="xml">
                <graph string="Employee Analytics">
                    <field name="department_id" type="row"/>
                    <field name="employee_count" type="measure"/>
                    <field name="active_employee_count" type="measure"/>
                    <field name="on_probation_count" type="measure"/>
                    <field name="contract_expiring_count" type="measure"/>
                    <field name="disciplinary_action_count" type="measure"/>
                    <field name="skill_gap_count" type="measure"/>
                </graph>
            </field>
        </record>
        
        <!-- Employee Status Report Form View -->
        <record id="hr_employee_status_report_view_form" model="ir.ui.view">
            <field name="name">hr.employee.status.report.form</field>
            <field name="model">hr.employee.status.report</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="employee_id"/>
                                <field name="department_id"/>
                                <field name="job_id"/>
                                <field name="manager_id"/>
                                <field name="hire_date"/>
                            </group>
                            <group>
                                <field name="active"/>
                                <field name="is_on_probation"/>
                                <field name="has_expiring_contract"/>
                                <field name="has_skill_gaps"/>
                                <field name="has_disciplinary_actions"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="disciplinary_action_count"/>
                                <field name="active_disciplinary_count"/>
                                <field name="skill_gap_count"/>
                            </group>
                            <group>
                                <field name="probation_end_date"/>
                                <field name="contract_end_date"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        
        <!-- Employee Status Report Tree View -->
        <record id="hr_employee_status_report_view_tree" model="ir.ui.view">
            <field name="name">hr.employee.status.report.tree</field>
            <field name="model">hr.employee.status.report</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="employee_id"/>
                    <field name="department_id"/>
                    <field name="job_id"/>
                    <field name="manager_id"/>
                    <field name="active"/>
                    <field name="is_on_probation"/>
                    <field name="has_expiring_contract"/>
                    <field name="has_skill_gaps"/>
                    <field name="has_disciplinary_actions"/>
                    <field name="disciplinary_action_count"/>
                    <field name="skill_gap_count"/>
                    <field name="hire_date"/>
                </tree>
            </field>
        </record>
        
        <!-- Employee Status Report Pivot View -->
        <record id="hr_employee_status_report_view_pivot" model="ir.ui.view">
            <field name="name">hr.employee.status.report.pivot</field>
            <field name="model">hr.employee.status.report</field>
            <field name="arch" type="xml">
                <pivot string="Employee Status Report">
                    <field name="department_id" type="row"/>
                    <field name="job_id" type="row"/>
                    <field name="active" type="col"/>
                    <field name="disciplinary_action_count" type="measure"/>
                    <field name="skill_gap_count" type="measure"/>
                </pivot>
            </field>
        </record>
        
        <!-- Employee Status Report Graph View -->
        <record id="hr_employee_status_report_view_graph" model="ir.ui.view">
            <field name="name">hr.employee.status.report.graph</field>
            <field name="model">hr.employee.status.report</field>
            <field name="arch" type="xml">
                <graph string="Employee Status Report">
                    <field name="department_id" type="row"/>
                    <field name="active" type="col"/>
                    <field name="disciplinary_action_count" type="measure"/>
                    <field name="skill_gap_count" type="measure"/>
                </graph>
            </field>
        </record>
        
        <!-- Dashboard Widget Form View -->
        <record id="hr_dashboard_widget_view_form" model="ir.ui.view">
            <field name="name">hr.dashboard.widget.form</field>
            <field name="model">hr.dashboard.widget</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="widget_type"/>
                                <field name="sequence"/>
                            </group>
                            <group>
                                <field name="active"/>
                            </group>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        
        <!-- Dashboard Widget Tree View -->
        <record id="hr_dashboard_widget_view_tree" model="ir.ui.view">
            <field name="name">hr.dashboard.widget.tree</field>
            <field name="model">hr.dashboard.widget</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="widget_type"/>
                    <field name="sequence"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>
        
        <!-- Dashboard Widget Kanban View -->
        <record id="hr_dashboard_widget_view_kanban" model="ir.ui.view">
            <field name="name">hr.dashboard.widget.kanban</field>
            <field name="model">hr.dashboard.widget</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile">
                    <field name="name"/>
                    <field name="widget_type"/>
                    <field name="active"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="oe_kanban_card">
                                    <div class="oe_kanban_content">
                                        <div class="oe_kanban_details">
                                            <strong class="o_kanban_record_title">
                                                <field name="name" readonly="1"/>
                                            </strong>
                                            <div class="o_kanban_tags_section">
                                                <div class="oe_kanban_tags">
                                                    <span class="badge badge-pill badge-info" t-if="widget_type">
                                                        <field name="widget_type" readonly="1"/>
                                                    </span>
                                                    <span class="badge badge-pill badge-success" t-if="active">
                                                        Active
                                                    </span>
                                                    <span class="badge badge-pill badge-secondary" t-if="not active">
                                                        Inactive
                                                    </span>
                                                </div>
                                            </div>
                                            <div>
                                                <field name="description"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
        
        <!-- Analytics Actions -->
        <record id="action_hr_employee_analytics" model="ir.actions.act_window">
            <field name="name">Employee Analytics</field>
            <field name="res_model">hr.employee.analytics</field>
            <field name="view_mode">tree,pivot,graph</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No employee analytics data found
                </p>
                <p>
                    Employee analytics will be populated automatically based on employee data.
                </p>
            </field>
        </record>
        
        <record id="action_hr_employee_status_report" model="ir.actions.act_window">
            <field name="name">Employee Status Report</field>
            <field name="res_model">hr.employee.status.report</field>
            <field name="view_mode">tree,pivot,graph</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No employee status reports found
                </p>
                <p>
                    Employee status reports will be generated automatically based on employee data.
                </p>
            </field>
        </record>
        
        <record id="action_hr_dashboard_widget" model="ir.actions.act_window">
            <field name="name">HR Dashboard Widgets</field>
            <field name="res_model">hr.dashboard.widget</field>
            <field name="view_mode">tree,kanban,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No dashboard widgets found
                </p>
                <p>
                    Create dashboard widgets to display key HR metrics and analytics.
                </p>
            </field>
        </record>
        
    </data>
</odoo>
