<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Daily cron job for contract expiration notifications -->
        <record id="ir_cron_check_contract_expirations" model="ir.cron">
            <field name="name">SurePay HR: Check Contract Expirations</field>
            <field name="model_id" ref="model_hr_contract"/>
            <field name="state">code</field>
            <field name="code">model.check_contract_expirations()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>
        
        <!-- Daily cron job for employee contract expiration notifications -->
        <record id="ir_cron_check_employee_contract_expirations" model="ir.cron">
            <field name="name">SurePay HR: Check Employee Contract Expirations</field>
            <field name="model_id" ref="model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model._check_contract_expirations()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>
        
        <!-- Weekly cron job for skill gap analysis report -->
        <record id="ir_cron_weekly_skill_gap_report" model="ir.cron">
            <field name="name">SurePay HR: Weekly Skill Gap Report</field>
            <field name="model_id" ref="model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model._generate_weekly_skill_gap_report()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>
        
        <!-- Monthly cron job for HR analytics dashboard -->
        <record id="ir_cron_monthly_hr_analytics" model="ir.cron">
            <field name="name">SurePay HR: Monthly Analytics Report</field>
            <field name="model_id" ref="model_hr_employee_analytics"/>
            <field name="state">code</field>
            <field name="code">model._generate_monthly_report()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>
        
    </data>
</odoo>
