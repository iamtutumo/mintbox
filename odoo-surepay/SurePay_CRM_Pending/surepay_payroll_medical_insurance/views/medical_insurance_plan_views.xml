<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Medical Insurance Plan Tree View -->
        <record id="medical_insurance_plan_view_tree" model="ir.ui.view">
            <field name="name">medical.insurance.plan.tree</field>
            <field name="model">medical.insurance.plan</field>
            <field name="arch" type="xml">
                <tree string="Medical Insurance Plans">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="insurance_provider"/>
                    <field name="monthly_premium"/>
                    <field name="employee_contribution_rate"/>
                    <field name="employer_contribution_rate"/>
                    <field name="coverage_amount"/>
                    <field name="is_active"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </tree>
            </field>
        </record>

        <!-- Medical Insurance Plan Form View -->
        <record id="medical_insurance_plan_view_form" model="ir.ui.view">
            <field name="name">medical.insurance.plan.form</field>
            <field name="model">medical.insurance.plan</field>
            <field name="arch" type="xml">
                <form string="Medical Insurance Plan">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                                <field name="is_active" widget="boolean_toggle"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Plan Name"/>
                            </h1>
                            <h2>
                                <field name="code" placeholder="Plan Code"/>
                            </h2>
                        </div>
                        <group>
                            <group>
                                <field name="insurance_provider"/>
                                <field name="policy_number"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                            <group>
                                <field name="coverage_start_date"/>
                                <field name="coverage_end_date"/>
                                <field name="is_active"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Plan Details">
                                <group>
                                    <group>
                                        <field name="monthly_premium"/>
                                        <field name="coverage_amount"/>
                                        <field name="deductible_amount"/>
                                        <field name="max_out_of_pocket"/>
                                    </group>
                                    <group>
                                        <field name="employee_contribution_rate"/>
                                        <field name="employer_contribution_rate"/>
                                        <field name="co_payment_percentage"/>
                                    </group>
                                </group>
                                <group>
                                    <field name="description"/>
                                </group>
                            </page>
                            <page string="Employees">
                                <field name="employee_ids">
                                    <tree>
                                        <field name="name"/>
                                        <field name="work_email"/>
                                        <field name="medical_insurance_number"/>
                                        <field name="medical_insurance_start_date"/>
                                        <field name="medical_insurance_end_date"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Claims">
                                <field name="claim_ids">
                                    <tree>
                                        <field name="name"/>
                                        <field name="claim_date"/>
                                        <field name="claim_type"/>
                                        <field name="total_amount"/>
                                        <field name="approved_amount"/>
                                        <field name="claim_status"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Medical Insurance Plan Search View -->
        <record id="medical_insurance_plan_view_search" model="ir.ui.view">
            <field name="name">medical.insurance.plan.search</field>
            <field name="model">medical.insurance.plan</field>
            <field name="arch" type="xml">
                <search string="Medical Insurance Plans">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="insurance_provider"/>
                    <separator/>
                    <filter name="active" string="Active" domain="[('is_active', '=', True)]"/>
                    <filter name="inactive" string="Inactive" domain="[('is_active', '=', False)]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter name="group_provider" string="Provider" context="{'group_by': 'insurance_provider'}"/>
                        <filter name="group_company" string="Company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Medical Insurance Plan Action -->
        <record id="action_medical_insurance_plan" model="ir.actions.act_window">
            <field name="name">Medical Insurance Plans</field>
            <field name="res_model">medical.insurance.plan</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first medical insurance plan
                </p>
                <p>
                    Medical insurance plans define the coverage, premiums, and benefits 
                    available to employees. You can configure different plans with various 
                    coverage levels and contribution rates.
                </p>
            </field>
        </record>

        <!-- Menu Items -->
        <menuitem id="menu_medical_insurance_root" 
                  name="Medical Insurance" 
                  parent="hr.menu_hr_root" 
                  sequence="100"/>
        
        <menuitem id="menu_medical_insurance_plan" 
                  name="Insurance Plans" 
                  parent="menu_medical_insurance_root" 
                  action="action_medical_insurance_plan" 
                  sequence="10"/>

    </data>
</odoo>
