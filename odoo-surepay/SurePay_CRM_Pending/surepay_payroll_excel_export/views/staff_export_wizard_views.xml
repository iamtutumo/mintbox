<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Staff Export Wizard Form View -->
        <record id="view_staff_export_wizard_form" model="ir.ui.view">
            <field name="name">staff.export.wizard.form</field>
            <field name="model">staff.export.wizard</field>
            <field name="arch" type="xml">
                <form string="Export Staff Data">
                    <sheet>
                        <group>
                            <group>
                                <field name="template_id"/>
                                <field name="company_id"/>
                                <field name="file_name"/>
                            </group>
                            <group>
                                <field name="date_from"/>
                                <field name="date_to"/>
                            </group>
                        </group>
                        
                        <notebook>
                            <page string="Employee Selection">
                                <group>
                                    <field name="employee_ids" widget="many2many_tags"/>
                                    <field name="department_id"/>
                                </group>
                            </page>
                            
                            <page string="Export Options">
                                <group>
                                    <field name="include_current_data"/>
                                    <field name="include_empty_editable_fields"/>
                                    <field name="include_instructions"/>
                                    <field name="include_validation"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button name="action_export_staff_data" string="Export Data" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Staff Export Wizard Action -->
        <record id="action_staff_export_wizard" model="ir.actions.act_window">
            <field name="name">Export Staff Data</field>
            <field name="res_model">staff.export.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{}</field>
        </record>

    </data>
</odoo>
