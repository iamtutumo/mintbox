<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Staff Export Template Tree View -->
        <record id="view_staff_export_template_tree" model="ir.ui.view">
            <field name="name">staff.export.template.tree</field>
            <field name="model">staff.export.template</field>
            <field name="arch" type="xml">
                <tree string="Staff Export Templates">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="company_id"/>
                    <field name="active"/>
                    <field name="include_basic_info"/>
                    <field name="include_allowances"/>
                    <field name="include_deductions"/>
                </tree>
            </field>
        </record>

        <!-- Staff Export Template Form View -->
        <record id="view_staff_export_template_form" model="ir.ui.view">
            <field name="name">staff.export.template.form</field>
            <field name="model">staff.export.template</field>
            <field name="arch" type="xml">
                <form string="Staff Export Template">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_export_staff_data" type="object" class="oe_stat_button" icon="fa-download" string="Export Data"/>
                        </div>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="company_id"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="description"/>
                            </group>
                        </group>
                        
                        <notebook>
                            <page string="Template Sections">
                                <group>
                                    <field name="include_basic_info"/>
                                    <field name="include_employment_details"/>
                                    <field name="include_current_salary"/>
                                    <field name="include_allowances"/>
                                    <field name="include_deductions"/>
                                    <field name="include_fines"/>
                                    <field name="include_loans"/>
                                    <field name="include_tax_info"/>
                                    <field name="include_bank_details"/>
                                </group>
                            </page>
                            
                            <page string="Editable Fields">
                                <group>
                                    <field name="editable_basic_salary"/>
                                    <field name="editable_allowances"/>
                                    <field name="editable_deductions"/>
                                    <field name="editable_fines"/>
                                    <field name="editable_overtime"/>
                                    <field name="editable_bonus"/>
                                    <field name="editable_commission"/>
                                </group>
                            </page>
                            
                            <page string="Allowance Types">
                                <field name="allowance_type_ids">
                                    <tree editable="bottom">
                                        <field name="name"/>
                                        <field name="code"/>
                                        <field name="note"/>
                                    </tree>
                                </field>
                            </page>
                            
                            <page string="Deduction Types">
                                <field name="deduction_type_ids">
                                    <tree editable="bottom">
                                        <field name="name"/>
                                        <field name="code"/>
                                        <field name="note"/>
                                    </tree>
                                </field>
                            </page>
                            
                            <page string="Fine Types">
                                <field name="fine_type_ids">
                                    <tree editable="bottom">
                                        <field name="name"/>
                                        <field name="code"/>
                                        <field name="description"/>
                                    </tree>
                                </field>
                            </page>
                            
                            <page string="Excel Formatting">
                                <group>
                                    <group>
                                        <field name="header_color"/>
                                        <field name="editable_color"/>
                                        <field name="header_font_size"/>
                                        <field name="data_font_size"/>
                                    </group>
                                    <group>
                                        <field name="file_prefix"/>
                                        <field name="include_company_logo"/>
                                        <field name="include_instructions"/>
                                        <field name="include_validation_sheet"/>
                                    </group>
                                </group>
                            </page>
                            
                            <page string="Default Values">
                                <group>
                                    <group>
                                        <field name="default_basic_salary"/>
                                        <field name="default_working_days"/>
                                        <field name="default_overtime_rate"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Staff Export Template Search View -->
        <record id="view_staff_export_template_search" model="ir.ui.view">
            <field name="name">staff.export.template.search</field>
            <field name="model">staff.export.template</field>
            <field name="arch" type="xml">
                <search string="Staff Export Templates">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="description"/>
                    <separator/>
                    <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                    <filter name="inactive" string="Inactive" domain="[('active', '=', False)]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter name="group_company" string="Company" context="{'group_by': 'company_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Staff Export Template Action -->
        <record id="action_staff_export_template" model="ir.actions.act_window">
            <field name="name">Staff Export Templates</field>
            <field name="res_model">staff.export.template</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first staff export template
                </p>
                <p>
                    Staff export templates allow you to configure how employee data is exported to Excel for payroll processing.
                </p>
            </field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_staff_export_template" 
                  name="Staff Export Templates" 
                  parent="surepay_payroll.menu_surepay_payroll_root" 
                  action="action_staff_export_template" 
                  sequence="10"/>

    </data>
</odoo>
