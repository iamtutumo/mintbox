<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="application_status_page" model="ir.ui.view">
        <field name="name">Application Status</field>
        <field name="type">qweb</field>
        <field name="key">hr_applicant_tracking_random.application_status_page</field>
        <field name="arch" type="xml">
            <t t-name="hr_applicant_tracking_random.application_status_page">
                <t t-call="website.layout">
                    <div id="wrap" class="oe_structure">
                        <div class="container mt-4">
                            <div class="row justify-content-center">
                                <div class="col-lg-8">
                                    <div class="card">
                                        <div class="card-header bg-primary text-white">
                                            <h2 class="h4 mb-0">Check Your Application Status</h2>
                                        </div>
                                        <div class="card-body">
                                            <t t-if="status == 'found' and applicant">
                                                <div class="alert alert-success">
                                                    <h4 class="alert-heading">Application Found!</h4>
                                                    <p>Hello <t t-esc="applicant.partner_name or 'Applicant'"/>,</p>
                                                    <p>Your application for <strong><t t-esc="applicant.job_id.name or 'the position'"/></strong>
                                                        is currently in the <strong><t t-esc="applicant.stage_id.name or 'application'"/></strong> stage.
                                                    </p>
                                                    <hr/>
                                                    <p class="mb-0">
                                                        <strong>Tracking ID:</strong> <t t-esc="applicant.tracking_id"/><br/>
                                                        <strong>Applied on:</strong> <t t-esc="applicant.create_date.strftime('%B %d, %Y') if applicant.create_date else 'N/A'"/><br/>
                                                        <strong>Last Update:</strong> <t t-esc="applicant.write_date.strftime('%B %d, %Y at %I:%M %p') if applicant.write_date else 'N/A'"/>
                                                    </p>
                                                </div>
                                                <div class="text-center mt-4">
                                                    <a href="/" class="btn btn-primary">Back to Home</a>
                                                </div>
                                            </t>
                                            <t t-elif="status == 'not_found'">
                                                <div class="alert alert-warning">
                                                    <h4 class="alert-heading">Application Not Found</h4>
                                                    <p>We couldn't find an application with the provided details. Please check your tracking ID and email address and try again.</p>
                                                    <hr/>
                                                    <p class="mb-0">If you've lost your tracking ID, please contact our HR department for assistance.</p>
                                                </div>
                                                <div class="text-center mt-4">
                                                    <a href="/job/status" class="btn btn-primary">Try Again</a>
                                                    <a href="/" class="btn btn-outline-secondary ml-2">Back to Home</a>
                                                </div>
                                            </t>
                                            <t t-else="">
                                                <form action="/job/status" method="post" class="needs-validation" novalidate="">
                                                    <div class="form-group">
                                                        <label for="tracking_id">Tracking ID <span class="text-danger">*</span></label>
                                                        <input type="text" class="form-control" id="tracking_id" name="tracking_id" 
                                                               placeholder="Enter your tracking ID (e.g., APP-12345678)" required="required"/>
                                                        <div class="invalid-feedback">
                                                            Please provide your tracking ID.
                                                        </div>
                                                    </div>
                                                    <div class="form-group mt-3">
                                                        <label for="email">Email Address</label>
                                                        <input type="email" class="form-control" id="email" name="email" 
                                                               placeholder="Enter your email (optional but recommended)"/>
                                                        <small class="form-text text-muted">
                                                            Providing your email helps us verify your identity more securely.
                                                        </small>
                                                    </div>
                                                    <div class="text-center mt-4">
                                                        <button type="submit" class="btn btn-primary btn-lg">Check Status</button>
                                                    </div>
                                                </form>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </field>
    </record>

    <!-- Application Confirmation Page -->
    <record id="application_confirmation" model="ir.ui.view">
        <field name="name">Application Confirmation</field>
        <field name="type">qweb</field>
        <field name="key">hr_applicant_tracking_random.application_confirmation</field>
        <field name="arch" type="xml">
            <t t-name="hr_applicant_tracking_random.application_confirmation">
                <t t-call="website.layout">
                    <div id="wrap" class="oe_structure">
                        <div class="container">
                            <div class="row justify-content-center mt-5 mb-5">
                                <div class="col-lg-8">
                                    <div class="card">
                                        <div class="card-header bg-success text-white text-center">
                                            <h2 class="h3 mb-0">Application Submitted Successfully!</h2>
                                        </div>
                                        <div class="card-body text-center">
                                            <div class="py-4">
                                                <i class="fa fa-check-circle text-success" style="font-size: 5rem; margin-bottom: 1.5rem;"></i>
                                                <h3 class="h4 mb-3">Thank You for Your Application</h3>
                                                <p class="lead">We've received your application.</p>
                                                <div class="alert alert-info text-left mt-4">
                                                    <h4 class="h5">Your Application Details</h4>
                                                    <p class="mb-1"><strong>Tracking ID:</strong> <t t-esc="tracking_id or 'Not available'"/></p>
                                                    <p class="mb-0">Please save this tracking ID to check the status of your application.</p>
                                                </div>
                                                <div class="mt-4">
                                                    <p>We'll review your application and contact you if your qualifications match our requirements.</p>
                                                    <p>You can check your application status anytime using the link below:</p>
                                                    <a t-attf-href="/applicant/tracking/{{ tracking_id }}" class="btn btn-primary mt-2">
                                                        Check Application Status
                                                    </a>
                                                </div>
                                            </div>
                                            <div class="mt-4 pt-3 border-top">
                                                <a href="/" class="btn btn-outline-secondary">
                                                    <i class="fa fa-home"></i> Back to Home
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </field>
    </record>
</odoo>