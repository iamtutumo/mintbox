<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="crm_lead_stage_view_form_inherit" model="ir.ui.view">
            <field name="name">crm.lead.stage.form.inherit.duration</field>
            <field name="model">crm.stage</field>
            <field name="inherit_id" ref="crm.crm_stage_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="allowed_duration_days"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>