<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Record Rules for Evaluation Access -->
    
    <!-- HR Users can see all evaluations -->
    <record id="evaluation_hr_rule" model="ir.rule">
        <field name="name">HR: All Evaluations</field>
        <field name="model_id" ref="model_hr_applicant_evaluation"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr_recruitment.group_hr_recruitment_user'))]"/>
    </record>
    
</odoo>
