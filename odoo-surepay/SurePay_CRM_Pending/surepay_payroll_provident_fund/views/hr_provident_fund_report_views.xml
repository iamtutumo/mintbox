<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Provident Fund Report Action -->
        <record id="action_hr_provident_fund_report" model="ir.actions.act_window">
            <field name="name">Provident Fund Report</field>
            <field name="res_model">surepay_payroll.hr.payslip</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'search_default_has_provident_fund': 1, 'group_by': 'date_from', 'group_by_no_leaf': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No payslips with Provident Fund found
                </p>
                <p>
                    This report shows Provident Fund deductions across all payslips.
                    You can analyze Provident Fund contributions by employee, department, date, and other dimensions.
                </p>
            </field>
        </record>

        <!-- Menu item for Provident Fund Report -->
        <menuitem id="menu_hr_provident_fund_report"
                  name="Provident Fund Report"
                  parent="surepay_payroll.menu_surepay_payroll_root"
                  action="action_hr_provident_fund_report"
                  sequence="65"/>

    </data>
</odoo>
