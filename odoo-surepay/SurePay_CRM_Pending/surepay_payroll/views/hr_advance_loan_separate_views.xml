<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Pure Salary Advances (advance_loan_type = 'advance') -->
        <record id="view_hr_salary_advance_only_tree" model="ir.ui.view">
            <field name="name">hr.salary.advance.only.tree</field>
            <field name="model">surepay_payroll.hr.salary.advance</field>
            <field name="arch" type="xml">
                <tree string="Salary Advances" decoration-info="status=='draft'" 
                      decoration-warning="status in ['submitted','hr_officer_approved']" 
                      decoration-success="status=='active'" 
                      decoration-muted="status in ['completed','cancelled']"
                      decoration-danger="status=='rejected'">
                    <field name="employee_id"/>
                    <field name="amount_requested"/>
                    <field name="amount_approved"/>
                    <field name="outstanding_balance"/>
                    <field name="total_repaid"/>
                    <field name="status"/>
                    <field name="request_date"/>
                    <field name="repayment_start_date"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </tree>
            </field>
        </record>

        <record id="view_hr_salary_advance_only_kanban" model="ir.ui.view">
            <field name="name">hr.salary.advance.only.kanban</field>
            <field name="model">surepay_payroll.hr.salary.advance</field>
            <field name="arch" type="xml">
                <kanban class="o_hr_employee_kanban">
                    <field name="employee_id"/>
                    <field name="amount_requested"/>
                    <field name="amount_approved"/>
                    <field name="outstanding_balance"/>
                    <field name="status"/>
                    <field name="request_date"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title">
                                        <field name="employee_id"/> - Salary Advance
                                    </strong>
                                    <div class="o_kanban_tags_section">
                                        <span class="badge badge-pill badge-info">
                                            Requested: <field name="amount_requested"/>
                                        </span>
                                        <span t-if="amount_approved" class="badge badge-pill badge-success">
                                            Approved: <field name="amount_approved"/>
                                        </span>
                                    </div>
                                    <div class="o_kanban_record_bottom">
                                        <div class="oe_kanban_bottom_right">
                                            <div class="oe_kanban_status">
                                                <field name="status" widget="kanban_state_selection"/>
                                            </div>
                                        </div>
                                        <div class="oe_kanban_bottom_left">
                                            <span class="text-muted">Outstanding: <field name="outstanding_balance"/></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="view_hr_salary_advance_only_search" model="ir.ui.view">
            <field name="name">hr.salary.advance.only.search</field>
            <field name="model">surepay_payroll.hr.salary.advance</field>
            <field name="arch" type="xml">
                <search string="Salary Advances">
                    <field name="employee_id"/>
                    <field name="status"/>
                    <field name="request_date"/>
                    <separator/>
                    <filter name="draft" string="Draft" domain="[('status', '=', 'draft')]"/>
                    <filter name="submitted" string="Submitted" domain="[('status', '=', 'submitted')]"/>
                    <filter name="hr_officer_approved" string="HR Officer Approved" domain="[('status', '=', 'hr_officer_approved')]"/>
                    <filter name="active" string="Active" domain="[('status', '=', 'active')]"/>
                    <filter name="completed" string="Completed" domain="[('status', '=', 'completed')]"/>
                    <filter name="rejected" string="Rejected" domain="[('status', '=', 'rejected')]"/>
                    <separator/>
                    <filter name="my_advances" string="My Advances" domain="[('employee_id.user_id', '=', uid)]"/>
                    <filter name="outstanding" string="Outstanding Balance" domain="[('outstanding_balance', '>', 0)]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter name="group_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                        <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                        <filter name="group_date" string="Date" context="{'group_by': 'request_date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_hr_salary_advance_only" model="ir.actions.act_window">
            <field name="name">Salary Advances</field>
            <field name="res_model">surepay_payroll.hr.salary.advance</field>
            <field name="view_mode">tree,form,kanban,pivot,graph</field>
            <field name="domain">[('advance_loan_type', '=', 'advance')]</field>
            <field name="context">{'search_default_my_advances': 1, 'default_advance_loan_type': 'advance'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new salary advance
                </p>
                <p>
                    Manage salary advances with approval workflow and payroll deduction tracking.
                </p>
            </field>
        </record>

        <!-- Pure Loans (advance_loan_type = 'loan') -->
        <record id="view_hr_loan_only_tree" model="ir.ui.view">
            <field name="name">hr.loan.only.tree</field>
            <field name="model">surepay_payroll.hr.salary.advance</field>
            <field name="arch" type="xml">
                <tree string="Loans" decoration-info="status=='draft'" 
                      decoration-warning="status in ['submitted','hr_officer_approved']" 
                      decoration-success="status=='active'" 
                      decoration-muted="status in ['completed','cancelled']"
                      decoration-danger="status=='rejected'">
                    <field name="employee_id"/>
                    <field name="amount_requested"/>
                    <field name="amount_approved"/>
                    <field name="interest_rate"/>
                    <field name="total_interest"/>
                    <field name="total_repayable"/>
                    <field name="outstanding_balance"/>
                    <field name="total_repaid"/>
                    <field name="status"/>
                    <field name="request_date"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </tree>
            </field>
        </record>

        <record id="view_hr_loan_only_kanban" model="ir.ui.view">
            <field name="name">hr.loan.only.kanban</field>
            <field name="model">surepay_payroll.hr.salary.advance</field>
            <field name="arch" type="xml">
                <kanban class="o_hr_employee_kanban">
                    <field name="employee_id"/>
                    <field name="amount_requested"/>
                    <field name="amount_approved"/>
                    <field name="interest_rate"/>
                    <field name="total_interest"/>
                    <field name="total_repayable"/>
                    <field name="outstanding_balance"/>
                    <field name="status"/>
                    <field name="request_date"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title">
                                        <field name="employee_id"/> - Loan
                                    </strong>
                                    <div class="o_kanban_tags_section">
                                        <span class="badge badge-pill badge-info">
                                            Requested: <field name="amount_requested"/>
                                        </span>
                                        <span t-if="amount_approved" class="badge badge-pill badge-success">
                                            Approved: <field name="amount_approved"/>
                                        </span>
                                        <span t-if="total_interest > 0" class="badge badge-pill badge-warning">
                                            Interest: <field name="total_interest"/>
                                        </span>
                                    </div>
                                    <div class="o_kanban_record_bottom">
                                        <div class="oe_kanban_bottom_right">
                                            <div class="oe_kanban_status">
                                                <field name="status" widget="kanban_state_selection"/>
                                            </div>
                                        </div>
                                        <div class="oe_kanban_bottom_left">
                                            <span class="text-muted">Outstanding: <field name="outstanding_balance"/></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="view_hr_loan_only_search" model="ir.ui.view">
            <field name="name">hr.loan.only.search</field>
            <field name="model">surepay_payroll.hr.salary.advance</field>
            <field name="arch" type="xml">
                <search string="Loans">
                    <field name="employee_id"/>
                    <field name="status"/>
                    <field name="request_date"/>
                    <separator/>
                    <filter name="draft" string="Draft" domain="[('status', '=', 'draft')]"/>
                    <filter name="submitted" string="Submitted" domain="[('status', '=', 'submitted')]"/>
                    <filter name="hr_officer_approved" string="HR Officer Approved" domain="[('status', '=', 'hr_officer_approved')]"/>
                    <filter name="active" string="Active" domain="[('status', '=', 'active')]"/>
                    <filter name="completed" string="Completed" domain="[('status', '=', 'completed')]"/>
                    <filter name="rejected" string="Rejected" domain="[('status', '=', 'rejected')]"/>
                    <separator/>
                    <filter name="my_loans" string="My Loans" domain="[('employee_id.user_id', '=', uid)]"/>
                    <filter name="outstanding" string="Outstanding Balance" domain="[('outstanding_balance', '>', 0)]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter name="group_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                        <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                        <filter name="group_date" string="Date" context="{'group_by': 'request_date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_hr_loan_only" model="ir.actions.act_window">
            <field name="name">Loans</field>
            <field name="res_model">surepay_payroll.hr.salary.advance</field>
            <field name="view_mode">tree,form,kanban,pivot,graph</field>
            <field name="domain">[('advance_loan_type', '=', 'loan')]</field>
            <field name="context">{'search_default_my_loans': 1, 'default_advance_loan_type': 'loan'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new loan
                </p>
                <p>
                    Manage employee loans with interest rates, approval workflow, and installment-based repayment tracking.
                </p>
            </field>
        </record>

        <!-- Updated Menu Structure -->
        <menuitem id="menu_hr_salary_advance_only"
                  name="Salary Advances"
                  parent="menu_hr_salary_advance_root"
                  action="action_hr_salary_advance_only"
                  sequence="10"/>
        
        <menuitem id="menu_hr_loan_only"
                  name="Loans"
                  parent="menu_hr_salary_advance_root"
                  action="action_hr_loan_only"
                  sequence="20"/>

        <!-- Legacy Employee Loans Menu (for backward compatibility) -->
        <menuitem id="menu_hr_loan_legacy"
                  name="Employee Loans (Legacy)"
                  parent="menu_hr_salary_advance_root"
                  action="action_hr_loan"
                  sequence="30"
                  groups="surepay_payroll.group_surepay_payroll_manager"/>

    </data>
</odoo>
