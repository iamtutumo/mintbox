<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Salary Advance Tree View -->
        <record id="view_hr_salary_advance_tree" model="ir.ui.view">
            <field name="name">hr.salary.advance.tree</field>
            <field name="model">surepay_payroll.hr.salary.advance</field>
            <field name="arch" type="xml">
                <tree string="Salary Advances" decoration-info="status=='draft'" 
                      decoration-warning="status in ['submitted','hr_officer_approved']" 
                      decoration-success="status in ['approved','active','paid']" 
                      decoration-muted="status in ['completed','cancelled']"
                      decoration-danger="status=='rejected'">
                    <field name="employee_id"/>
                    <field name="amount_requested"/>
                    <field name="outstanding_balance"/>
                    <field name="total_repaid"/>
                    <field name="status"/>
                    <field name="date_requested"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="request_date"/>
                    <field name="repayment_start_date"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </tree>
            </field>
        </record>

        <!-- Salary Advance Form View -->
        <record id="view_hr_salary_advance_form" model="ir.ui.view">
            <field name="name">hr.salary.advance.form</field>
            <field name="model">surepay_payroll.hr.salary.advance</field>
            <field name="priority">99</field>
            <field name="arch" type="xml">
                <form string="Salary Advance">
                    <header>
                        <!-- Standard Workflow Buttons -->
                        <button name="action_submit" string="Submit" type="object" 
                                class="btn-primary" invisible="status != 'draft'">
                            <i class="fa fa-paper-plane" title="Submit for Approval"/>
                        </button>
                        <button name="action_approve" string="Approve" type="object" 
                                class="btn-success"
                                groups="surepay_payroll.group_surepay_payroll_user"
                                invisible="status != 'submitted'">
                            <i class="fa fa-check" title="Approve"/>
                        </button>
                        <button name="action_reject" string="Reject" type="object" 
                                class="btn-danger"
                                groups="surepay_payroll.group_surepay_payroll_user"
                                invisible="status not in ['submitted', 'approved']">
                            <i class="fa fa-times" title="Reject"/>
                        </button>
                        <button name="action_mark_paid" string="Complete" type="object" 
                                class="btn-info"
                                groups="surepay_payroll.group_surepay_payroll_user"
                                invisible="status != 'approved'">
                            <i class="fa fa-money" title="Mark as Paid"/>
                        </button>
                        
                        <!-- Status Bar on Right Side -->
                        <field name="status" widget="statusbar" statusbar_visible="draft,submitted,approved,paid"/>
                    </header>
                    
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_payslip_deductions" type="object" 
                                    class="oe_stat_button" icon="fa-money" 
                                    invisible="payslip_line_ids == []">
                                <field name="payslip_line_count" widget="statinfo" string="Deductions"/>
                                <field name="total_deducted" widget="monetary" string="Total Deducted"/>
                            </button>
                            <button name="action_view_employee" type="object" 
                                    class="oe_stat_button" icon="fa-user" 
                                    invisible="employee_id == False">
                                <field name="employee_id" widget="statinfo" string="Employee"/>
                            </button>
                        </div>
                        
                        <div class="oe_title">
                            <h1>
                                <field name="employee_id" readonly="1"/>
                            </h1>
                            <h2>
                                Salary Advance Request
                            </h2>
                        </div>
                        
                        <group>
                            <group>
                                <field name="employee_id" readonly="status != 'draft'"/>
                                <field name="amount_requested" readonly="status != 'draft'"/>
                                <field name="date_requested" readonly="1"/>
                            </group>
                            <group>
                                <field name="currency_id" readonly="1"/>
                                <field name="company_id" readonly="1" groups="base.group_multi_company"/>
                            </group>
                            </group>
                        </group>
                        
                        <!-- Loan financial summary -->
                        <group string="Loan Financial Summary" invisible="advance_loan_type != 'loan'">
                            <group>
                                <field name="total_interest" readonly="1"/>
                                <field name="total_repayable" readonly="1"/>
                            </group>
                        </group>
                        
                        <!-- Repayment plan section -->
                        <group string="Repayment Plan">
                            <group>
                                <field name="repayment_plan" readonly="status not in ['draft', 'submitted']"/>
                                <field name="repayment_start_date" readonly="status not in ['draft', 'submitted']"/>
                                <field name="repayment_method" readonly="status not in ['draft', 'submitted']"/>
                                <field name="bank_account_id" domain="[('partner_id', '=', employee_id.address_home_id)]" invisible="repayment_method != 'bank_transfer'" readonly="status not in ['draft', 'submitted']"/>
                                <field name="auto_deduct" readonly="status not in ['draft', 'submitted']"/>
                            </group>
                            <group invisible="repayment_plan not in ['installments', 'bi_weekly', 'weekly']">
                                <field name="installment_amount" readonly="status not in ['draft', 'submitted']"/>
                                <field name="number_of_installments" readonly="status not in ['draft', 'submitted']"/>
                                <field name="installments_paid" readonly="1"/>
                                <field name="next_installment_date" readonly="1"/>
                                <field name="last_installment_date" readonly="1"/>
                            </group>
                        </group>
                        
                        <separator string="Deduction Information"/>
                        <group>
                            <div class="alert alert-info" role="alert">
                                <strong>How Deductions Work:</strong> This salary advance will be automatically deducted from the employee's next payroll. The full amount will be deducted as a single payment from the upcoming payslip.
                            </div>
                            <group>
                                <field name="outstanding_balance" readonly="1"/>
                                <field name="total_repaid" readonly="1"/>
                            </group>
                        </group>
                        
                        <separator string="Rejection Reason" invisible="status != 'rejected'"/>
                        <field name="rejection_reason" placeholder="Reason for rejection..."
                               invisible="status != 'rejected'" readonly="status != 'rejected'"/>
                        <separator string="Payslip Deductions"/>
                        <field name="payslip_line_ids" readonly="1">
                            <tree>
                                <field name="slip_id"/>
                                <field name="date_from"/>
                                <field name="date_to"/>
                                <field name="total"/>
                            </tree>
                        </field>
                        
                        <group>
                            <group string="Submission Info">
                                <field name="submission_date" readonly="1"/>
                                <field name="submitted_by" readonly="1"/>
                            </group>
                            <group string="Approval Info">
                                <field name="hr_approval_date" readonly="1"/>
                                <field name="hr_officer_approved_by" readonly="1"/>
                                <field name="manager_approval_date" readonly="1"/>
                                <field name="hr_manager_approved_by" readonly="1"/>
                                <field name="completion_date" readonly="1"/>
                            </group>
                        </group>
                        
                        <separator string="Notes"/>
                        <group>
                            <group>
                                <field name="hr_officer_notes" placeholder="HR Officer notes and comments..."
                                       readonly="status not in ['submitted', 'hr_officer_approved']"
                                       groups="surepay_payroll.group_surepay_payroll_user"/>
                            </group>
                            <group>
                                <field name="hr_manager_notes" placeholder="HR Manager notes and comments..."
                                       readonly="status not in ['hr_officer_approved', 'active']"
                                       groups="surepay_payroll.group_surepay_payroll_manager"/>
                            </group>
                        </group>
                        
                        <separator string="Rejection Reason" invisible="status != 'rejected'"/>
                        <field name="rejection_reason" placeholder="Reason for rejection..."
                               readonly="status != 'rejected'"/>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Salary Advance Kanban View -->
        <record id="view_hr_salary_advance_kanban" model="ir.ui.view">
            <field name="name">hr.salary.advance.kanban</field>
            <field name="model">surepay_payroll.hr.salary.advance</field>
            <field name="arch" type="xml">
                <kanban class="o_hr_employee_kanban">
                    <field name="employee_id"/>
                    <field name="advance_loan_type"/>
                    <field name="amount_requested"/>
                    <field name="amount_approved"/>
                    <field name="outstanding_balance"/>
                    <field name="status"/>
                    <field name="repayment_plan"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title">
                                        <field name="employee_id"/> - 
                                        <field name="advance_loan_type"/>
                                    </strong>
                                    <div class="o_kanban_tags_section">
                                        <span class="badge badge-pill badge-info">
                                            Requested: <field name="amount_requested"/>
                                        </span>
                                        <span t-if="amount_approved" class="badge badge-pill badge-success">
                                            Approved: <field name="amount_approved"/>
                                        </span>
                                        <span t-if="total_interest > 0" class="badge badge-pill badge-warning">
                                            Interest: <field name="total_interest"/>
                                        </span>
                                    </div>
                                    <div class="o_kanban_record_bottom">
                                        <div class="oe_kanban_bottom_right">
                                            <div class="oe_kanban_status">
                                                <field name="status" widget="kanban_state_selection"/>
                                            </div>
                                        </div>
                                        <div class="oe_kanban_bottom_left">
                                            <span class="text-muted">Outstanding: <field name="outstanding_balance"/></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Salary Advance Search View -->
        <record id="view_hr_salary_advance_search" model="ir.ui.view">
            <field name="name">hr.salary.advance.search</field>
            <field name="model">surepay_payroll.hr.salary.advance</field>
            <field name="arch" type="xml">
                <search string="Salary Advances & Loans">
                    <field name="employee_id"/>
                    <field name="advance_loan_type"/>
                    <field name="status"/>
                    <separator/>
                    <filter name="advances" string="Advances" domain="[('advance_loan_type', '=', 'advance')]"/>
                    <filter name="loans" string="Loans" domain="[('advance_loan_type', '=', 'loan')]"/>
                    <separator/>
                    <filter name="draft" string="Draft" domain="[('status', '=', 'draft')]"/>
                    <filter name="submitted" string="Submitted" domain="[('status', '=', 'submitted')]"/>
                    <filter name="hr_officer_approved" string="HR Officer Approved" domain="[('status', '=', 'hr_officer_approved')]"/>
                    <filter name="hr_manager_approved" string="HR Manager Approved" domain="[('status', '=', 'hr_manager_approved')]"/>
                    <filter name="active" string="Active" domain="[('status', '=', 'active')]"/>
                    <filter name="completed" string="Completed" domain="[('status', '=', 'completed')]"/>
                    <filter name="cancelled" string="Cancelled" domain="[('status', '=', 'cancelled')]"/>
                    <filter name="rejected" string="Rejected" domain="[('status', '=', 'rejected')]"/>
                    <separator/>
                    <filter name="my_advances" string="My Advances" domain="[('employee_id.user_id', '=', uid)]"/>
                    <filter name="outstanding" string="With Outstanding Balance" domain="[('outstanding_balance', '>', 0)]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter name="group_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                        <filter name="group_type" string="Type" context="{'group_by': 'advance_loan_type'}"/>
                        <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                        <filter name="group_repayment_plan" string="Repayment Plan" context="{'group_by': 'repayment_plan'}"/>
                        <filter name="group_company" string="Company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Salary Advance Pivot View -->
        <record id="view_hr_salary_advance_pivot" model="ir.ui.view">
            <field name="name">hr.salary.advance.pivot</field>
            <field name="model">surepay_payroll.hr.salary.advance</field>
            <field name="arch" type="xml">
                <pivot string="Salary Advances & Loans Analysis">
                    <field name="advance_loan_type" type="row"/>
                    <field name="employee_id" type="row"/>
                    <field name="status" type="col"/>
                    <field name="amount_requested" type="measure"/>
                    <field name="amount_approved" type="measure"/>
                    <field name="total_interest" type="measure"/>
                    <field name="total_repayable" type="measure"/>
                    <field name="outstanding_balance" type="measure"/>
                    <field name="total_repaid" type="measure"/>
                </pivot>
            </field>
        </record>

        <!-- Salary Advance Graph View -->
        <record id="view_hr_salary_advance_graph" model="ir.ui.view">
            <field name="name">hr.salary.advance.graph</field>
            <field name="model">surepay_payroll.hr.salary.advance</field>
            <field name="arch" type="xml">
                <graph string="Salary Advances Analysis">
                    <field name="employee_id"/>
                    <field name="amount_requested" type="measure"/>
                    <field name="amount_approved" type="measure"/>
                    <field name="outstanding_balance" type="measure"/>
                </graph>
            </field>
        </record>

        <!-- Salary Advance Action -->
        <record id="action_hr_salary_advance" model="ir.actions.act_window">
            <field name="name">Salary Advances & Loans</field>
            <field name="res_model">surepay_payroll.hr.salary.advance</field>
            <field name="view_mode">tree,form,kanban,pivot,graph</field>
            <field name="context">{'search_default_outstanding': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first salary advance request
                </p>
                <p>
                    Employees can request salary advances and loans through this system. 
                    The requests go through an approval workflow and repayments are automatically 
                    deducted from payroll.
                </p>
            </field>
        </record>

        <!-- My Salary Advances Action -->
        <record id="action_my_salary_advance" model="ir.actions.act_window">
            <field name="name">My Salary Advances</field>
            <field name="res_model">surepay_payroll.hr.salary.advance</field>
            <field name="view_mode">tree,form,kanban</field>
            <field name="domain">[('employee_id.user_id', '=', uid)]</field>
            <field name="context">{'search_default_my_advances': 1}</field>
        </record>

    </data>
</odoo>
