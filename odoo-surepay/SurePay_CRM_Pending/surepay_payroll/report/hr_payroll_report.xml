<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--Report action for Contribution Register Report-->
        <record id="contribution_register_action" model="ir.actions.report">
            <field name="name">Contribution Register PDF</field>
            <field name="model">hr.contribution.register</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">surepay_payroll.report_contributionregister</field>
            <field name="report_file">surepay_payroll.report_contributionregister</field>
        </record>
        <!--  Main Payslip Report Action -->
        <record id="hr_payslip_new_report_action" model="ir.actions.report">
            <field name="name">Payslip Report</field>
            <field name="model">surepay_payroll.hr.payslip</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">surepay_payroll.report_payslip</field>
            <field name="report_file">surepay_payroll.report_payslip</field>
            <field name="print_report_name">('Payslip - %s' % (object.employee_id.name))</field>
            <field name="binding_model_id" ref="surepay_payroll.model_surepay_payroll_hr_payslip"/>
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>
