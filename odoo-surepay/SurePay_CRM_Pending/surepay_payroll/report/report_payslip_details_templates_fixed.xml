<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Fixed Template for Payslip Details Report with Proper Company Layout -->
    <template id="report_payslipdetails_fixed">
        <!-- Include payroll assets for proper print styling -->
        <t t-call="surepay_payroll.payroll_report_assets"/>
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <!-- Use web.external_layout for company branding -->
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Company Header (will be provided by web.external_layout) -->
                        
                        <!-- Professional Payslip Header -->
                        <div class="text-center mb-4" style="margin-top: 20px;">
                            <h2 class="mb-2" style="color: #2c3e50; font-weight: bold; border-bottom: 2px solid #3498db; padding-bottom: 10px;">PAY SLIP DETAILS</h2>
                            <h4 class="text-muted mb-0" t-field="o.name"/>
                            <div class="text-muted small">
                                Period: <span t-field="o.date_from"/> to <span t-field="o.date_to"/>
                            </div>
                        </div>
                        
                        <!-- Employee Information Table -->
                        <div class="table-responsive mb-4">
                            <table class="table table-sm table-bordered" style="border: 1px solid #dee2e6;">
                                <thead class="bg-light" style="background-color: #f8f9fa !important;">
                                    <tr>
                                        <th colspan="4" class="text-center" style="background-color: #e9ecef; font-weight: bold;">Employee Information</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td width="20%" style="font-weight: bold;">Employee Name</td>
                                        <td width="30%"><span t-field="o.employee_id"/></td>
                                        <td width="20%" style="font-weight: bold;">Designation</td>
                                        <td width="30%"><span t-field="o.employee_id.job_id"/></td>
                                    </tr>
                                    <tr>
                                        <td style="font-weight: bold;">Email</td>
                                        <td><span t-field="o.employee_id.work_email"/></td>
                                        <td style="font-weight: bold;">Identification No</td>
                                        <td><span t-field="o.employee_id.identification_id"/></td>
                                    </tr>
                                    <tr>
                                        <td style="font-weight: bold;">Payslip No</td>
                                        <td><span t-field="o.number"/></td>
                                        <td style="font-weight: bold;">Bank Account</td>
                                        <td><span t-field="o.employee_id.bank_account_id"/></td>
                                    </tr>
                                    <tr>
                                        <td style="font-weight: bold;">Department</td>
                                        <td><span t-field="o.employee_id.department_id"/></td>
                                        <td style="font-weight: bold;">Work Location</td>
                                        <td><span t-field="o.employee_id.work_location_id"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        
                        <!-- Details by Salary Rule Category -->
                        <div class="card mb-4" style="border: 1px solid #dee2e6;">
                            <div class="card-header bg-light" style="background-color: #f8f9fa !important;">
                                <h5 class="mb-0">Details by Salary Rule Category</h5>
                            </div>
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered table-striped" style="border: 1px solid #dee2e6;">
                                        <thead class="bg-light" style="background-color: #f8f9fa !important;">
                                            <tr>
                                                <th width="10%" style="font-weight: bold;">Code</th>
                                                <th width="60%" style="font-weight: bold;">Salary Rule Category</th>
                                                <th width="30%" class="text-right" style="font-weight: bold;">Total</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-if="get_details_by_rule_category.get(o.id, [])">
                                                <tr t-foreach="get_details_by_rule_category.get(o.id, [])" t-as="h">
                                                    <td><span t-esc="h['code']"/></td>
                                                    <td>
                                                        <span class="ms-2" t-esc="'..'*h['level']"/>
                                                        <span t-esc="h['rule_category']"/>
                                                    </td>
                                                    <td class="text-right">
                                                        <span t-esc="h['total']" 
                                                              t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                                    </td>
                                                </tr>
                                            </t>
                                            <t t-if="not get_details_by_rule_category.get(o.id, [])">
                                                <tr>
                                                    <td colspan="3" class="text-center text-muted">No salary rule categories available</td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Payslip Lines by Contribution Register -->
                        <div class="card mb-4" style="border: 1px solid #dee2e6;">
                            <div class="card-header bg-light" style="background-color: #f8f9fa !important;">
                                <h5 class="mb-0">Payslip Lines by Contribution Register</h5>
                            </div>
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered table-striped" style="border: 1px solid #dee2e6;">
                                        <thead class="bg-light" style="background-color: #f8f9fa !important;">
                                            <tr>
                                                <th width="15%" style="font-weight: bold;">Register</th>
                                                <th width="55%" style="font-weight: bold;">Description</th>
                                                <th width="30%" class="text-right" style="font-weight: bold;">Total</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-if="get_lines_by_contribution_register.get(o.id, [])">
                                                <tr t-foreach="get_lines_by_contribution_register.get(o.id, [])" t-as="register">
                                                    <td><span t-esc="register['name']"/></td>
                                                    <td><span t-esc="register['code']"/></td>
                                                    <td class="text-right">
                                                        <span t-esc="register['total']" 
                                                              t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                                    </td>
                                                </tr>
                                            </t>
                                            <t t-if="not get_lines_by_contribution_register.get(o.id, [])">
                                                <tr>
                                                    <td colspan="3" class="text-center text-muted">No contribution registers available</td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Summary Section -->
                        <div class="row mb-4">
                            <div class="col-8">
                                <div class="card" style="border: 1px solid #dee2e6;">
                                    <div class="card-header bg-light" style="background-color: #f8f9fa !important;">
                                        <h5 class="mb-0">Report Summary</h5>
                                    </div>
                                    <div class="card-body">
                                        <table class="table table-sm mb-0">
                                            <tr>
                                                <td width="50%" style="font-weight: bold;">Gross Wage:</td>
                                                <td width="50%" class="text-right">
                                                    <span t-esc="o.gross_wage" t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="font-weight: bold;">Total Deductions:</td>
                                                <td class="text-right">
                                                    <span t-esc="o.total_ded" t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="font-weight: bold;">Net Wage:</td>
                                                <td class="text-right">
                                                    <span t-esc="o.net_wage" t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="card" style="border: 1px solid #dee2e6;">
                                    <div class="card-header bg-light" style="background-color: #f8f9fa !important;">
                                        <h5 class="mb-0">Payment Info</h5>
                                    </div>
                                    <div class="card-body">
                                        <table class="table table-sm mb-0">
                                            <tr>
                                                <td style="font-weight: bold;">Payment Date:</td>
                                                <td><span t-field="o.credit_note"/></td>
                                            </tr>
                                            <tr>
                                                <td style="font-weight: bold;">Status:</td>
                                                <td><span t-field="o.state"/></td>
                                            </tr>
                                            <tr>
                                                <td style="font-weight: bold;">Company:</td>
                                                <td><span t-field="o.company_id.name"/></td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Signatures -->
                        <div class="row mt-5">
                            <div class="col-6 text-center">
                                <div class="border-bottom mb-2" style="height: 1px;"></div>
                                <p class="mb-0"><strong>Employee Signature</strong></p>
                                <p class="text-muted small">_________________________</p>
                            </div>
                            <div class="col-6 text-center">
                                <div class="border-bottom mb-2" style="height: 1px;"></div>
                                <p class="mb-0"><strong>Authorized Signature</strong></p>
                                <p class="text-muted small">_________________________</p>
                            </div>
                        </div>
                        
                        <!-- Company Footer (will be provided by web.external_layout) -->
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
