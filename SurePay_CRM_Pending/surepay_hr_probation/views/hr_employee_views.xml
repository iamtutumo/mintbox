<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="hr_employee_view_form_inherit_probation" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.probation</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='active']" position="after">
                    <field name="is_probation"/>
                    <field name="probation_start_date" invisible="not is_probation"/>
                    <field name="probation_end_date" invisible="not is_probation"/>
                </xpath>
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="toggle_probation" type="object" 
                            class="oe_stat_button" 
                            icon="fa-check-circle" 
                            invisible="is_probation == False"
                            title="Toggle Probation Status">
                        <field name="is_probation" widget="boolean_toggle" readonly="1"/>
                        <div class="o_field_widget">
                            <span class="text-success" invisible="is_probation == False">
                                <i class="fa fa-check-circle"/> On Probation
                            </span>
                        </div>
                    </button>
                </xpath>
            </field>
        </record>

        <record id="hr_employee_view_kanban_inherit_probation" model="ir.ui.view">
            <field name="name">hr.employee.kanban.inherit.probation</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.hr_kanban_view_employees"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='id']" position="after">
                    <field name="is_probation"/>
                </xpath>
                <xpath expr="//div[@class='oe_kanban_details']" position="inside">
                    <div class="oe_kanban_tags">
                        <span class="badge badge-success" invisible="is_probation == False">
                            <i class="fa fa-check-circle"/> Probation
                        </span>
                    </div>
                </xpath>
            </field>
        </record>

        <record id="hr_employee_view_tree_inherit_probation" model="ir.ui.view">
            <field name="name">hr.employee.tree.inherit.probation</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_tree"/>
            <field name="arch" type="xml">
                <field name="work_phone" position="after">
                    <field name="is_probation"/>
                    <field name="probation_status"/>
                </field>
            </field>
        </record>

        <record id="hr_employee_view_search_inherit_probation" model="ir.ui.view">
            <field name="name">hr.employee.search.inherit.probation</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_filter"/>
            <field name="arch" type="xml">
                <filter name="inactive" position="after">
                    <separator/>
                    <filter name="on_probation" string="On Probation" domain="[('is_probation', '=', True)]"/>
                    <filter name="not_on_probation" string="Not on Probation" domain="[('is_probation', '=', False)]"/>
                    <filter name="probation_expired" string="Probation Expired" domain="[('probation_status', '=', 'expired')]"/>
                </filter>
                <group position="inside">
                    <filter name="group_probation_status" string="Probation Status" context="{'group_by': 'probation_status'}"/>
                </group>
            </field>
        </record>
</odoo>
