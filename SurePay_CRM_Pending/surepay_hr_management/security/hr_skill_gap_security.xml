<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Security Group for Skill Gap Management -->
        <record id="group_skill_gap_user" model="res.groups">
            <field name="name">Skill Gap User</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">User can view and manage skill gaps for their employees.</field>
        </record>

        <record id="group_skill_gap_manager" model="res.groups">
            <field name="name">Skill Gap Manager</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="implied_ids" eval="[(4, ref('group_skill_gap_user')), (4, ref('hr.group_hr_user'))]"/>
            <field name="comment">Manager can view and manage skill gaps for all employees in their department.</field>
        </record>

        <record id="group_skill_gap_admin" model="res.groups">
            <field name="name">Skill Gap Administrator</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="implied_ids" eval="[(4, ref('group_skill_gap_manager')), (4, ref('hr.group_hr_manager'))]"/>
            <field name="comment">Administrator can manage all skill gaps in the company.</field>
        </record>

        <!-- Access Rights for hr.skill.gap -->
        <record id="access_hr_skill_gap_user" model="ir.model.access">
            <field name="name">hr.skill.gap.user</field>
            <field name="model_id" ref="model_hr_skill_gap"/>
            <field name="group_id" ref="group_skill_gap_user"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="access_hr_skill_gap_manager" model="ir.model.access">
            <field name="name">hr.skill.gap.manager</field>
            <field name="model_id" ref="model_hr_skill_gap"/>
            <field name="group_id" ref="group_skill_gap_manager"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <record id="access_hr_skill_gap_admin" model="ir.model.access">
            <field name="name">hr.skill.gap.admin</field>
            <field name="model_id" ref="model_hr_skill_gap"/>
            <field name="group_id" ref="group_skill_gap_admin"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- Record Rules for hr.skill.gap -->
        
        <!-- Users can only see skill gaps for their employees -->
        <record id="hr_skill_gap_rule_user" model="ir.rule">
            <field name="name">Skill Gap User Rule</field>
            <field name="model_id" ref="model_hr_skill_gap"/>
            <field name="domain_force">['|', ('employee_id.parent_id.user_id', '=', user.id), ('identified_by', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_skill_gap_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Managers can see skill gaps for their department -->
        <record id="hr_skill_gap_rule_manager" model="ir.rule">
            <field name="name">Skill Gap Manager Rule</field>
            <field name="model_id" ref="model_hr_skill_gap"/>
            <field name="domain_force">['|', ('department_id.manager_id.user_id', '=', user.id), ('employee_id.department_id.manager_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_skill_gap_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- Administrators can see all skill gaps -->
        <record id="hr_skill_gap_rule_admin" model="ir.rule">
            <field name="name">Skill Gap Admin Rule</field>
            <field name="model_id" ref="model_hr_skill_gap"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_skill_gap_admin'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- Multi-company rule -->
        <record id="hr_skill_gap_rule_company" model="ir.rule">
            <field name="name">Skill Gap Multi-company Rule</field>
            <field name="model_id" ref="model_hr_skill_gap"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'child_of', [user.company_id.id])]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

    </data>
</odoo>
