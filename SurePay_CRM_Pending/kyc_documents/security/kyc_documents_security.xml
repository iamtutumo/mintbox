<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Security Groups -->
    <record id="group_kyc_compliance_officer" model="res.groups">
        <field name="name">Compliance Officer</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <!-- Record Rules -->
    <record id="kyc_document_rule_user" model="ir.rule">
        <field name="name">KYC Document User</field>
        <field name="model_id" ref="model_surepay_kyc_document"/>
        <field name="domain_force">['|', ('uploaded_by', '=', user.id), ('lead_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="kyc_document_rule_compliance" model="ir.rule">
        <field name="name">KYC Document Compliance Officer</field>
        <field name="model_id" ref="model_surepay_kyc_document"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('kyc_documents.group_kyc_compliance_officer'))]"/>
    </record>
</odoo>
