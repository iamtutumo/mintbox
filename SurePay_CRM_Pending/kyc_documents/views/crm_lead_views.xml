<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add KYC Documents tab to CRM Lead form -->
    <record id="view_crm_case_opportunities_form_inherit_kyc" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.kyc</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <!-- Add KYC Documents tab after the Extra Info tab -->
            <xpath expr="//page[@name='extra']" position="after">
                <page string="KYC Documents" name="kyc_documents" groups="base.group_system">
                    <field name="kyc_document_ids" context="{'default_lead_id': id}">
                        <tree>
                            <field name="name"/>
                            <field name="status"/>
                            <field name="uploaded_by"/>
                            <field name="uploaded_date"/>
                        </tree>
                        <form>
                            <field name="name"/>
                            <field name="file" filename="file_name"/>
                            <field name="description"/>
                            <field name="status"/>
                            <field name="uploaded_by" readonly="1"/>
                            <field name="uploaded_date" readonly="1"/>
                        </form>
                    </field>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" groups="base.group_user"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </page>
            </xpath>
            
            
        </field>
    </record>
</odoo>
