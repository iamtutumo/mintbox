<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sales Supervisor Group -->
        <record id="group_sales_supervisor" model="res.groups">
            <field name="name">Sales Supervisor</field>
            <field name="category_id" ref="base.module_category_sales_crm"/>
            <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        </record>

        <!-- Record Rules -->
        <record id="crm_lead_own_records_rule" model="ir.rule">
            <field name="name">CRM Lead: Own Records Only</field>
            <field name="model_id" ref="model_crm_lead"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        </record>

        <record id="crm_lead_all_records_rule" model="ir.rule">
            <field name="name">CRM Lead: All Records</field>
            <field name="model_id" ref="model_crm_lead"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('surepay_enhanced_crm.group_sales_supervisor'))]"/>
        </record>
    </data>
</odoo>