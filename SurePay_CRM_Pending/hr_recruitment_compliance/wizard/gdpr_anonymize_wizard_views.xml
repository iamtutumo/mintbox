<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- GDPR Anonymize Wizard -->
    <record id="view_gdpr_anonymize_wizard_form" model="ir.ui.view">
        <field name="name">gdpr.anonymize.wizard.form</field>
        <field name="model">gdpr.anonymize.wizard</field>
        <field name="arch" type="xml">
            <form string="Anonymize Applicant Data">
                <group>
                    <field name="applicant_id" readonly="1"/>
                    <field name="reason" placeholder="Enter reason for anonymization..."/>
                    <field name="confirm"/>
                </group>
                <div class="alert alert-warning">
                    <strong>Warning:</strong> This action cannot be undone. All personal data will be permanently anonymized.
                </div>
                <footer>
                    <button name="action_anonymize" string="Anonymize Data" type="object" class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
