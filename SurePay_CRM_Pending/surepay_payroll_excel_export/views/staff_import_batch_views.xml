<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Staff Import Batch Tree View -->
        <record id="view_staff_import_batch_tree" model="ir.ui.view">
            <field name="name">staff.import.batch.tree</field>
            <field name="model">staff.import.batch</field>
            <field name="arch" type="xml">
                <tree string="Staff Import Batches" decoration-info="state=='draft'" decoration-warning="state=='imported'" decoration-success="state=='completed'" decoration-danger="state=='cancelled'">
                    <field name="name"/>
                    <field name="template_id"/>
                    <field name="company_id"/>
                    <field name="state"/>
                    <field name="total_records"/>
                    <field name="valid_records"/>
                    <field name="error_records"/>
                    <field name="processed_records"/>
                    <field name="create_date"/>
                    <field name="import_user_id"/>
                </tree>
            </field>
        </record>

        <!-- Staff Import Batch Form View -->
        <record id="view_staff_import_batch_form" model="ir.ui.view">
            <field name="name">staff.import.batch.form</field>
            <field name="model">staff.import.batch</field>
            <field name="arch" type="xml">
                <form string="Staff Import Batch">
                    <header>
                        <button name="action_validate_all" string="Validate All" type="object" class="btn-primary" invisible="state not in ['draft', 'imported']"/>
                        <button name="action_process_batch" string="Process Batch" type="object" class="btn-primary" invisible="state != 'validated'"/>
                        <button name="action_cancel" string="Cancel" type="object" class="btn-secondary" invisible="state in ['completed', 'cancelled']"/>
                        <button name="action_reset_to_draft" string="Reset to Draft" type="object" class="btn-secondary" invisible="state != 'cancelled'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,imported,validated,processing"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_payslips" type="object" class="oe_stat_button" icon="fa-file-text-o" invisible="payslip_batch_id == False">
                                <field string="Payslips" name="payslip_count"/>
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="template_id"/>
                                <field name="company_id"/>
                                <field name="create_uid"/>
                                <field name="create_date"/>
                            </group>
                            <group>
                                <field name="import_user_id"/>
                                <field name="import_date"/>
                                <field name="payroll_period_start"/>
                                <field name="payroll_period_end"/>
                                <field name="payslip_batch_id"/>
                            </group>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                        
                        <notebook>
                            <page string="Import File">
                                <group>
                                    <field name="import_file" filename="import_filename"/>
                                    <field name="import_filename" invisible="1"/>
                                </group>
                            </page>
                            
                            <page string="Statistics">
                                <group>
                                    <group>
                                        <field name="total_records"/>
                                        <field name="valid_records"/>
                                        <field name="warning_records"/>
                                        <field name="error_records"/>
                                    </group>
                                    <group>
                                        <field name="processed_records"/>
                                        <field name="send_payslips_email"/>
                                        <field name="email_template_id"/>
                                    </group>
                                </group>
                            </page>
                            
                            <page string="Staff Data">
                                <field name="staff_data_ids">
                                    <tree decoration-success="validation_status=='valid'" decoration-warning="validation_status=='warning'" decoration-danger="validation_status=='error'">
                                        <field name="employee_code"/>
                                        <field name="employee_name"/>
                                        <field name="department"/>
                                        <field name="validation_status"/>
                                        <field name="is_processed"/>
                                        <field name="validation_messages"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Staff Import Batch Search View -->
        <record id="view_staff_import_batch_search" model="ir.ui.view">
            <field name="name">staff.import.batch.search</field>
            <field name="model">staff.import.batch</field>
            <field name="arch" type="xml">
                <search string="Staff Import Batches">
                    <field name="name"/>
                    <field name="description"/>
                    <field name="template_id"/>
                    <separator/>
                    <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="imported" string="Imported" domain="[('state', '=', 'imported')]"/>
                    <filter name="validated" string="Validated" domain="[('state', '=', 'validated')]"/>
                    <filter name="processing" string="Processing" domain="[('state', '=', 'processing')]"/>
                    <filter name="completed" string="Completed" domain="[('state', '=', 'completed')]"/>
                    <filter name="cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                        <filter name="group_template" string="Template" context="{'group_by': 'template_id'}"/>
                        <filter name="group_company" string="Company" context="{'group_by': 'company_id'}"/>
                        <filter name="group_user" string="Imported By" context="{'group_by': 'import_user_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Staff Import Batch Action -->
        <record id="action_staff_import_batch" model="ir.actions.act_window">
            <field name="name">Staff Import Batches</field>
            <field name="res_model">staff.import.batch</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'search_default_completed': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first staff import batch
                </p>
                <p>
                    Staff import batches allow you to import employee payroll data from Excel files and process them in bulk.
                </p>
            </field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_staff_import_batch" 
                  name="Staff Import Batches" 
                  parent="surepay_payroll.menu_surepay_payroll_root" 
                  action="action_staff_import_batch" 
                  sequence="20"/>

    </data>
</odoo>
