<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Exit Clearance Record Rules -->
        <record id="hr_exit_clearance_rule_employee" model="ir.rule">
            <field name="name">Exit Clearance: Employee can see their own</field>
            <field name="model_id" ref="model_hr_exit_clearance"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
        <record id="hr_exit_clearance_rule_manager" model="ir.rule">
            <field name="name">Exit Clearance: Manager can see all</field>
            <field name="model_id" ref="model_hr_exit_clearance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        
        <record id="hr_exit_clearance_line_rule_employee" model="ir.rule">
            <field name="name">Exit Clearance Line: Employee can see their own</field>
            <field name="model_id" ref="model_hr_exit_clearance_line"/>
            <field name="domain_force">[('clearance_id.employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
        <record id="hr_exit_clearance_line_rule_manager" model="ir.rule">
            <field name="name">Exit Clearance Line: Manager can see all</field>
            <field name="model_id" ref="model_hr_exit_clearance_line"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        
        <!-- Grievance Record Rules -->
        <record id="hr_grievance_rule_employee" model="ir.rule">
            <field name="name">Grievance: Employee can see their own</field>
            <field name="model_id" ref="model_hr_grievance"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
        <record id="hr_grievance_rule_officer" model="ir.rule">
            <field name="name">Grievance: HR Officer can see assigned and department</field>
            <field name="model_id" ref="model_hr_grievance"/>
            <field name="domain_force">['|', ('assigned_to.user_id', '=', user.id), ('employee_id.department_id.manager_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
        <record id="hr_grievance_rule_manager" model="ir.rule">
            <field name="name">Grievance: Manager can see all</field>
            <field name="model_id" ref="model_hr_grievance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        
        
    </data>
</odoo>
