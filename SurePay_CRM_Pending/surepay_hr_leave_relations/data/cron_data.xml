<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Annual Leave Allocation Cron Job -->
        <record id="ir_cron_annual_leave_allocation" model="ir.cron">
            <field name="name">Annual Leave Allocation</field>
            <field name="model_id" ref="model_hr_leave"/>
            <field name="state">code</field>
            <field name="code">model._create_annual_leave_allocation()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="numbercall">-1</field>
            <field name="doall">False</field>
            <field name="active">True</field>
            <!-- Run on January 1st at 2:00 AM -->
            <field name="nextcall" eval="datetime.datetime.strptime(datetime.datetime.now().strftime('%Y-01-01 02:00:00'), '%Y-%m-%d %H:%M:%S') if datetime.datetime.now().month == 1 and datetime.datetime.now().day == 1 else datetime.datetime.strptime(f'{datetime.datetime.now().year + 1}-01-01 02:00:00', '%Y-%m-%d %H:%M:%S')"/>
        </record>
        
        <!-- Leave Balance Notification Cron Job -->
        <record id="ir_cron_leave_balance_notification" model="ir.cron">
            <field name="name">Leave Balance Notification</field>
            <field name="model_id" ref="model_hr_leave"/>
            <field name="state">code</field>
            <field name="code">model._send_leave_balance_notifications()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="numbercall">-1</field>
            <field name="doall">False</field>
            <field name="active">True</field>
            <!-- Run on the 1st of every month at 9:00 AM -->
            <field name="nextcall" eval="datetime.datetime.now().replace(day=1, hour=9, minute=0, second=0, microsecond=0) + datetime.timedelta(days=32) if datetime.datetime.now().day > 1 else datetime.datetime.now().replace(day=1, hour=9, minute=0, second=0, microsecond=0)"/>
        </record>
        
    </data>
</odoo>
