<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Professional Purchase Requisition Report Template -->
    <template id="employee_purchase_requisition.report_purchase_requisition">
        <t t-call="employee_purchase_requisition.purchase_requisition_report_assets"/>
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="rec">
                <t t-call="web.external_layout">
                    <div class="page avoid-page-break">
                        <main>
                            <style>
                        .requisition-header {
                            text-align: center;
                            margin-bottom: 30px;
                            border-bottom: 2px solid #333;
                            padding-bottom: 15px;
                        }
                        .requisition-title {
                            font-size: 24px;
                            font-weight: bold;
                            color: #333;
                            margin: 0;
                        }
                        .requisition-subtitle {
                            font-size: 16px;
                            color: #666;
                            margin: 5px 0 0 0;
                        }
                        .status-badge {
                            display: inline-block;
                            padding: 5px 12px;
                            border-radius: 4px;
                            font-weight: bold;
                            font-size: 12px;
                            text-transform: uppercase;
                        }
                        .status-new { background-color: #e3f2fd; color: #1976d2; }
                        .status-waiting_department_approval { background-color: #fff3e0; color: #f57c00; }
                        .status-waiting_head_approval { background-color: #fce4ec; color: #c2185b; }
                        .status-approved { background-color: #e8f5e8; color: #388e3c; }
                        .status-purchase_order_created { background-color: #f3e5f5; color: #7b1fa2; }
                        .status-received { background-color: #e0f2f1; color: #00796b; }
                        .status-cancelled { background-color: #ffebee; color: #d32f2f; }
                        .info-table {
                            width: 100%;
                            border-collapse: collapse;
                            margin-bottom: 20px;
                        }
                        .info-table th {
                            background-color: #f5f5f5;
                            text-align: left;
                            padding: 8px 12px;
                            border: 1px solid #ddd;
                            font-weight: bold;
                            width: 20%;
                        }
                        .info-table td {
                            padding: 8px 12px;
                            border: 1px solid #ddd;
                            width: 30%;
                        }
                        .requisition-lines-table {
                            width: 100%;
                            border-collapse: collapse;
                            margin: 20px 0;
                        }
                        .requisition-lines-table th {
                            background-color: #f5f5f5;
                            text-align: left;
                            padding: 10px;
                            border: 1px solid #ddd;
                            font-weight: bold;
                        }
                        .requisition-lines-table td {
                            padding: 10px;
                            border: 1px solid #ddd;
                        }
                        .requisition-lines-table tr:nth-child(even) {
                            background-color: #f9f9f9;
                        }
                        .signature-section {
                            margin-top: 40px;
                            page-break-inside: avoid;
                        }
                        .signature-box {
                            display: inline-block;
                            width: 30%;
                            margin-right: 3%;
                            text-align: center;
                        }
                        .signature-line {
                            border-bottom: 1px solid #333;
                            height: 40px;
                            margin: 5px 0 2px 0;
                        }
                        .description-box {
                            background-color: #f9f9f9;
                            border: 1px solid #ddd;
                            padding: 15px;
                            margin: 15px 0;
                            border-radius: 4px;
                        }
                        .section-title {
                            font-size: 16px;
                            font-weight: bold;
                            color: #333;
                            margin: 25px 0 15px 0;
                            padding-bottom: 5px;
                            border-bottom: 1px solid #ddd;
                        }
                        .confidential {
                            color: #d32f2f;
                            font-weight: bold;
                            text-align: right;
            margin-bottom: 10px;
                        }
                        .card {
                            border: 1px solid #ddd;
                            margin-bottom: 20px;
                            page-break-inside: avoid;
                        }
                        .card-header {
                            background-color: #f8f9fa;
                            border-bottom: 1px solid #ddd;
                            padding: 10px 15px;
                            font-weight: bold;
                        }
                        .card-body {
                            padding: 15px;
                        }
                        .row {
                            display: flex;
                            flex-wrap: wrap;
                            margin: 0 -15px;
                        }
                        .col-md-4 {
                            flex: 0 0 33.333333%;
                            max-width: 33.333333%;
                            padding: 0 15px;
                        }
                        .mb-0 { margin-bottom: 0; }
                        .mb-1 { margin-bottom: 0.25rem; }
                        .mb-2 { margin-bottom: 0.5rem; }
                        .mb-3 { margin-bottom: 1rem; }
                        .mb-4 { margin-bottom: 1.5rem; }
                        .mt-2 { margin-top: 0.5rem; }
                        .mt-3 { margin-top: 1rem; }
                        .mt-4 { margin-top: 1.5rem; }
                        .text-center { text-align: center; }
                        .text-muted { color: #6c757d; }
                        .text-danger { color: #dc3545; }
                        .small { font-size: 80%; }
                        .font-weight-bold { font-weight: bold; }
                        .bg-primary { background-color: #007bff; color: white; }
                        .bg-info { background-color: #17a2b8; color: white; }
                        .bg-success { background-color: #28a745; color: white; }
                        .bg-warning { background-color: #ffc107; color: #212529; }
                        .bg-secondary { background-color: #6c757d; color: white; }
                        .bg-dark { background-color: #343a40; color: white; }
                        .text-white { color: white; }
                        .table-responsive {
                            overflow-x: auto;
                        }
                        .table {
                            width: 100%;
                            margin-bottom: 1rem;
                            background-color: transparent;
                        }
                        .table-sm th, .table-sm td {
                            padding: 0.3rem;
                        }
                        .table-bordered th, .table-bordered td {
                            border: 1px solid #dee2e6;
                        }
                        .table-striped tbody tr:nth-of-type(odd) {
                            background-color: rgba(0,0,0,.05);
                        }
                        .bg-light {
                            background-color: #f8f9fa;
                        }
                    </style>
                    
                        <!-- Professional Header -->
                        <div class="text-center mb-4" style="margin-top: 20px;">
                            <div class="confidential">CONFIDENTIAL</div>
                            <h2 class="mb-2" style="font-weight: bold; border-bottom: 3px solid #007bff; padding-bottom: 10px; color: #007bff;">PURCHASE REQUISITION</h2>
                            <h4 class="text-muted mb-0">Material Request Form</h4>
                            <div class="text-muted small mt-2">
                                <strong>Generated on:</strong> <span t-esc="datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')"/>
                            </div>
                            <div style="margin-top: 10px;">
                                <span class="status-badge" t-att-class="'status-' + rec.state">
                                    <t t-esc="rec.state.replace('_', ' ').title()"/>
                                </span>
                            </div>
                        </div>
                        
                        <!-- Basic Information Card -->
                        <div class="card mb-4">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0">Requisition Information</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-4">
                                        <strong>Requisition No:</strong>
                                        <p class="mb-0" t-esc="rec.name or 'N/A'"/>
                                    </div>
                                    <div class="col-md-4">
                                        <strong>Requisition Date:</strong>
                                        <p class="mb-0" t-esc="rec.requisition_date and rec.requisition_date.strftime('%Y-%m-%d') or 'N/A'"/>
                                    </div>
                                    <div class="col-md-4">
                                        <strong>Employee:</strong>
                                        <p class="mb-0" t-esc="rec.employee_id.name or 'N/A'"/>
                                    </div>
                                </div>
                                <div class="row mt-3">
                                    <div class="col-md-4">
                                        <strong>Department:</strong>
                                        <p class="mb-0" t-esc="rec.dept_id.name or 'N/A'"/>
                                    </div>
                                    <div class="col-md-4">
                                        <strong>Responsible Person:</strong>
                                        <p class="mb-0" t-esc="rec.user_id.name or 'N/A'"/>
                                    </div>
                                    <div class="col-md-4">
                                        <strong>Deadline:</strong>
                                        <p class="mb-0" t-esc="rec.requisition_deadline and rec.requisition_deadline.strftime('%Y-%m-%d') or 'N/A'"/>
                                    </div>
                                </div>
                                <div class="row mt-3">
                                    <div class="col-md-4">
                                        <strong>Company:</strong>
                                        <p class="mb-0" t-esc="rec.company_id.name or 'N/A'"/>
                                    </div>
                                    <div class="col-md-4">
                                        <strong>Received Date:</strong>
                                        <p class="mb-0" t-esc="rec.receive_date and rec.receive_date.strftime('%Y-%m-%d') or 'N/A'"/>
                                    </div>
                                    <div class="col-md-4">
                                        <strong>Status:</strong>
                                        <p class="mb-0">
                                            <span class="status-badge" t-att-class="'status-' + rec.state">
                                                <t t-esc="rec.state.replace('_', ' ').title()"/>
                                            </span>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Requisition Description Card -->
                        <t t-if="rec.requisition_description">
                            <div class="card mb-4">
                                <div class="card-header bg-info text-white">
                                    <h5 class="mb-0">Reason for Requisition</h5>
                                </div>
                                <div class="card-body">
                                    <p class="mb-0" t-esc="rec.requisition_description"/>
                                </div>
                            </div>
                        </t>
                        
                        <!-- Requisition Lines Card -->
                        <div class="card mb-4">
                            <div class="card-header bg-success text-white">
                                <h5 class="mb-0">Requisition Items</h5>
                            </div>
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered table-striped">
                                        <thead class="bg-light">
                                            <tr>
                                                <th width="15%">Type</th>
                                                <th width="25%">Product</th>
                                                <th width="35%">Description</th>
                                                <th width="10%" class="text-center">Quantity</th>
                                                <th width="15%">Unit of Measure</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="rec.requisition_order_ids" t-as="line">
                                                <tr>
                                                    <td>
                                                        <span t-if="line.requisition_type == 'internal_transfer'" class="status-badge status-new">Internal Transfer</span>
                                                        <span t-if="line.requisition_type == 'purchase_order'" class="status-badge status-approved">Purchase Order</span>
                                                    </td>
                                                    <td><strong t-esc="line.product_id.name or 'N/A'"/></td>
                                                    <td><t t-esc="line.description or 'N/A'"/></td>
                                                    <td class="text-center"><t t-esc="line.quantity or 0"/></td>
                                                    <td><t t-esc="line.uom or 'N/A'"/></td>
                                                </tr>
                                                <!-- Show vendor information for purchase orders -->
                                                <t t-if="line.requisition_type == 'purchase_order' and line.partner_id">
                                                    <tr>
                                                        <td colspan="5" style="background-color: #f0f8ff; font-style: italic;">
                                                            <strong>Preferred Vendor:</strong> <t t-esc="line.partner_id.name or 'N/A'"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </t>
                                            <!-- Show message if no lines -->
                                            <t t-if="not rec.requisition_order_ids">
                                                <tr>
                                                    <td colspan="5" class="text-center text-muted">
                                                        <em>No items found in this requisition</em>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Approval Workflow Card -->
                        <div class="card mb-4">
                            <div class="card-header bg-warning text-dark">
                                <h5 class="mb-0">Approval Workflow</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-4">
                                        <strong>Confirmed By:</strong>
                                        <p class="mb-0" t-esc="rec.confirm_id.name or 'N/A'"/>
                                    </div>
                                    <div class="col-md-4">
                                        <strong>Confirmed Date:</strong>
                                        <p class="mb-0" t-esc="rec.confirmed_date and rec.confirmed_date.strftime('%Y-%m-%d') or 'N/A'"/>
                                    </div>
                                    <div class="col-md-4">
                                        <strong>Department Manager:</strong>
                                        <p class="mb-0" t-esc="rec.manager_id.name or 'N/A'"/>
                                    </div>
                                </div>
                                <div class="row mt-3">
                                    <div class="col-md-4">
                                        <strong>Department Approval Date:</strong>
                                        <p class="mb-0" t-esc="rec.department_approval_date and rec.department_approval_date.strftime('%Y-%m-%d') or 'N/A'"/>
                                    </div>
                                    <div class="col-md-4">
                                        <strong>Approved By:</strong>
                                        <p class="mb-0" t-esc="rec.requisition_head_id.name or 'N/A'"/>
                                    </div>
                                    <div class="col-md-4">
                                        <strong>Approved Date:</strong>
                                        <p class="mb-0" t-esc="rec.approval_date and rec.approval_date.strftime('%Y-%m-%d') or 'N/A'"/>
                                    </div>
                                </div>
                                <t t-if="rec.state == 'cancelled'">
                                    <div class="row mt-3">
                                        <div class="col-md-4">
                                            <strong>Rejected By:</strong>
                                            <p class="mb-0 text-danger" t-esc="rec.rejected_user_id.name or 'N/A'"/>
                                        </div>
                                        <div class="col-md-4">
                                            <strong>Rejected Date:</strong>
                                            <p class="mb-0 text-danger" t-esc="rec.reject_date and rec.reject_date.strftime('%Y-%m-%d') or 'N/A'"/>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                        
                        <!-- Picking Details Card (if applicable) -->
                        <t t-if="rec.source_location_id or rec.destination_location_id">
                            <div class="card mb-4">
                                <div class="card-header bg-secondary text-white">
                                    <h5 class="mb-0">Picking &amp; Delivery Details</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <strong>Source Location:</strong>
                                            <p class="mb-0" t-esc="rec.source_location_id.name or 'N/A'"/>
                                        </div>
                                        <div class="col-md-4">
                                            <strong>Destination Location:</strong>
                                            <p class="mb-0" t-esc="rec.destination_location_id.name or 'N/A'"/>
                                        </div>
                                        <div class="col-md-4">
                                            <strong>Delivery Type:</strong>
                                            <p class="mb-0" t-esc="rec.delivery_type_id.name or 'N/A'"/>
                                        </div>
                                    </div>
                                    <t t-if="rec.internal_picking_id">
                                        <div class="row mt-3">
                                            <div class="col-md-4">
                                                <strong>Internal Picking:</strong>
                                                <p class="mb-0" t-esc="rec.internal_picking_id.name or 'N/A'"/>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </t>
                        
                        <!-- Signature Section Card -->
                        <div class="card mb-4">
                            <div class="card-header bg-dark text-white">
                                <h5 class="mb-0">Signatures</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-4 text-center">
                                        <div><strong>Employee Signature</strong></div>
                                        <div class="signature-line"></div>
                                        <div><small><span t-esc="rec.employee_id.name or 'Employee Name'"/></small></div>
                                        <div><small>Date: _______________</small></div>
                                    </div>
                                    <div class="col-md-4 text-center">
                                        <div><strong>Department Head</strong></div>
                                        <div class="signature-line"></div>
                                        <div><small><span t-esc="rec.manager_id.name or 'Manager Name'"/></small></div>
                                        <div><small>Date: _______________</small></div>
                                    </div>
                                    <div class="col-md-4 text-center">
                                        <div><strong>Approved By</strong></div>
                                        <div class="signature-line"></div>
                                        <div><small><span t-esc="rec.requisition_head_id.name or 'Approver Name'"/></small></div>
                                        <div><small>Date: _______________</small></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Professional Footer -->
                        <div class="text-center mt-4 text-muted small" style="border-top: 1px solid #dee2e6; padding-top: 15px;">
                            <p class="mb-1"><strong>Purchase Requisition Report</strong> - Employee Purchase Requisition System</p>
                            <p class="mb-0">This is a computer-generated report and does not require a physical signature.</p>
                            <div class="mt-2">
                                <small>
                                    Document generated on <t t-esc="datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')"/> | 
                                    Requisition ID: <t t-esc="rec.name"/> | 
                                    Page <span class="page"/> of <span class="topage"/>
                                </small>
                            </div>
                        </div>
                        </main>
                    </div>
                </t>
            </t>
            <t t-if="not docs">
                <t t-call="web.external_layout">
                    <div class="page">
                        <main>
                            <h1>Test Report</h1>
                            <p>No records found</p>
                        </main>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>

