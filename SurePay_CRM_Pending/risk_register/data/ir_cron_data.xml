<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Scheduled Action to Check Overdue Risks -->
        <record id="ir_cron_check_overdue_risks" model="ir.cron">
            <field name="name">Check Overdue Risks</field>
            <field name="model_id" ref="model_risk_register"/>
            <field name="state">code</field>
            <field name="code">model.check_overdue_risks()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall">False</field>
            <field name="active">True</field>
        </record>
        
    </data>
</odoo>
