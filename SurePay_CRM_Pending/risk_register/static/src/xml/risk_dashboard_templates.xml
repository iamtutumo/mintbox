<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="risk_dashboard_template">
        <div class="o_risk_dashboard">
            <div class="row">
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h3 class="mb-0">Risk Management Dashboard</h3>
                        <button class="btn btn-primary refresh-dashboard" type="button">
                            <i class="fa fa-refresh"/> Refresh
                        </button>
                    </div>
                </div>
            </div>

            <!-- Quick Stats Cards -->
            <div class="row mb-4">
                <div class="col-lg-3 col-md-6">
                    <div class="card bg-primary text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h4 class="card-title" id="total_risks">0</h4>
                                    <p class="card-text">Total Risks</p>
                                </div>
                                <div class="align-self-center">
                                    <i class="fa fa-exclamation-triangle fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="card bg-danger text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h4 class="card-title" id="overdue_risks">0</h4>
                                    <p class="card-text">Overdue Risks</p>
                                </div>
                                <div class="align-self-center">
                                    <i class="fa fa-clock-o fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="card bg-success text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h4 class="card-title" id="mitigated_risks">0</h4>
                                    <p class="card-text">Mitigated</p>
                                </div>
                                <div class="align-self-center">
                                    <i class="fa fa-check-circle fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="card bg-info text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h4 class="card-title" id="avg_risk_score">0</h4>
                                    <p class="card-text">Avg Risk Score</p>
                                </div>
                                <div class="align-self-center">
                                    <i class="fa fa-line-chart fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Charts Row 1 -->
            <div class="row mb-4">
                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-body">
                            <canvas id="risk_level_chart" width="400" height="300"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-body">
                            <canvas id="department_chart" width="400" height="300"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Charts Row 2 -->
            <div class="row mb-4">
                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-body">
                            <canvas id="status_chart" width="400" height="300"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-body">
                            <canvas id="timeline_chart" width="400" height="300"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Detailed Breakdowns Section -->
            <div class="row mb-4">
                <div class="col-12">
                    <h4 class="mb-3">Detailed Risk Analysis</h4>
                </div>
            </div>

            <!-- Risk Breakdown by Department and Status -->
            <div class="row mb-4">
                <div class="col-lg-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Risk Breakdown by Department and Status</h5>
                        </div>
                        <div class="card-body">
                            <canvas id="department_status_chart" width="800" height="400"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Risk Metrics Row -->
            <div class="row mb-4">
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Impact vs Likelihood Matrix</h5>
                        </div>
                        <div class="card-body">
                            <canvas id="impact_likelihood_chart" width="400" height="300"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Overdue Risks Analysis</h5>
                        </div>
                        <div class="card-body">
                            <div id="overdue_analysis">
                                <div class="text-center mb-3">
                                    <h3 id="avg_days_overdue">0</h3>
                                    <p class="text-muted">Average Days Overdue</p>
                                </div>
                                <div class="text-center">
                                    <h3 id="max_days_overdue">0</h3>
                                    <p class="text-muted">Maximum Days Overdue</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Risk Distribution</h5>
                        </div>
                        <div class="card-body">
                            <canvas id="risk_distribution_chart" width="400" height="300"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Top Risks Section -->
            <div class="row mb-4">
                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Top High-Risk Items</h5>
                        </div>
                        <div class="card-body">
                            <div id="top_high_risks">
                                <div class="list-group" id="high_risks_list">
                                    <!-- High risk items will be populated here -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Recent Risk Activities</h5>
                        </div>
                        <div class="card-body">
                            <div id="recent_activities">
                                <div class="list-group" id="activities_list">
                                    <!-- Recent activities will be populated here -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>
