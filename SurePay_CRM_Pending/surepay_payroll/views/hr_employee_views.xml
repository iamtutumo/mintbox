<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Employee View -->
        <record id="view_employee_form" model="ir.ui.view">
            <field name="name">hr.employee.view.form</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="%(action_hr_payslip)d"
                            class="oe_stat_button"
                            icon="fa-credit-card"
                            type="action"
                            groups="surepay_payroll.group_surepay_payroll_user">
                        <field name="payslip_count" widget="statinfo"
                               string="Payslips"/>
                    </button>
                    <button name="action_view_advances"
                            class="oe_stat_button"
                            icon="fa-money"
                            type="object"
                            groups="surepay_payroll.group_surepay_payroll_user">
                        <field name="advance_count" widget="statinfo"
                               string="Advances"/>
                        <field name="total_advance_outstanding" widget="statinfo"
                               string="Outstanding"/>
                    </button>
                    <button name="action_view_loans"
                            class="oe_stat_button"
                            icon="fa-credit-card"
                            type="object"
                            groups="surepay_payroll.group_surepay_payroll_user">
                        <field name="loan_count" widget="statinfo"
                               string="Loans"/>
                        <field name="total_loan_outstanding" widget="statinfo"
                               string="Outstanding"/>
                    </button>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
