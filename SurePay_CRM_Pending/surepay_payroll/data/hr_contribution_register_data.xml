            <field name="name">Tax Deductions Register</field>
            <field name="code">TAX_REG</field>
            <field name="company_id" ref="base.main_company"/>
        </record>
        
        <record id="contribution_register_deductions" model="hr.contribution.register">
            <field name="name">Other Deductions Register</field>
            <field name="code">DED_REG</field>
            <field name="company_id" ref="base.main_company"/>
        </record>
        
        <record id="contribution_register_net" model="hr.contribution.register">
            <field name="name">Net Salary Register</field>
            <field name="code">NET_REG</field>
            <field name="company_id" ref="base.main_company"/>
