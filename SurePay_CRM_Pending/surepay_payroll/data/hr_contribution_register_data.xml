<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Contribution Registers -->
        <record id="contribution_register_basic" model="hr.contribution.register">
            <field name="name">Basic Pay Register</field>
            <field name="code">BASIC_REG</field>
            <field name="company_id" ref="base.main_company"/>
        </record>
        
        <record id="contribution_register_allowances" model="hr.contribution.register">
            <field name="name">Allowances Register</field>
            <field name="code">ALW_REG</field>
            <field name="company_id" ref="base.main_company"/>
