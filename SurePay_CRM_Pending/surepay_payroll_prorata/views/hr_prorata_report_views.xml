<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Prorata Salary Report Action -->
        <record id="action_hr_prorata_report" model="ir.actions.act_window">
            <field name="name">Prorata Salary Report</field>
            <field name="res_model">surepay_payroll.hr.payslip</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'search_default_is_prorata': 1, 'group_by': 'date_from'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No prorata payslips found
                </p>
                <p>
                    This report shows prorata salary calculations across all payslips.
                    You can analyze prorata adjustments by employee, department, date, and prorata factor.
                </p>
            </field>
        </record>


        <!-- Prorata Salary Tree View -->
        <record id="view_hr_prorata_report_tree" model="ir.ui.view">
            <field name="name">hr.payslip.prorata.tree</field>
            <field name="model">surepay_payroll.hr.payslip</field>
            <field name="inherit_id" ref="surepay_payroll.hr_payslip_view_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='state']" position="after">
                    <field name="prorata_days_worked" optional="show"/>
                    <field name="prorata_total_days" optional="show"/>
                    <field name="prorata_factor" optional="show"/>
                </xpath>
                <xpath expr="//tree" position="attributes">
                    <attribute name="default_order">date_from desc</attribute>
                </xpath>
            </field>
        </record>

        <!-- Prorata Salary Search View -->
        <record id="view_hr_prorata_report_search" model="ir.ui.view">
            <field name="name">hr.payslip.prorata.search</field>
            <field name="model">surepay_payroll.hr.payslip</field>
            <field name="inherit_id" ref="surepay_payroll.hr_payslip_search"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='done']" position="after">
                    <separator/>
                    <filter name="is_prorata" string="Is Prorata" domain="[('is_prorata', '=', True)]"/>
                    <filter name="not_prorata" string="Not Prorata" domain="[('is_prorata', '=', False)]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter name="group_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                        <filter name="group_month" string="Month" context="{'group_by': 'date_from:month'}"/>
                        <filter name="group_year" string="Year" context="{'group_by': 'date_from:year'}"/>
                        <filter name="group_prorata_factor" string="Prorata Factor" context="{'group_by': 'prorata_factor'}"/>
                    </group>
                </xpath>
            </field>
        </record>

        <!-- Prorata Salary Details Action -->
        <record id="action_hr_prorata_details" model="ir.actions.act_window">
            <field name="name">Prorata Details</field>
            <field name="res_model">surepay_payroll.hr.payslip</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="view_hr_prorata_report_tree"/>
            <field name="context">{'search_default_is_prorata': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No prorata payslips found
                </p>
                <p>
                    This view shows detailed prorata salary calculations for employees who joined or left mid-month.
                </p>
            </field>
        </record>

        <!-- Menu items for Prorata Reports -->
        <menuitem id="menu_hr_prorata_report"
                  name="Prorata Salary Report"
                  parent="surepay_payroll.menu_surepay_payroll_root"
                  action="action_hr_prorata_report"
                  sequence="70"/>

        <menuitem id="menu_hr_prorata_details"
                  name="Prorata Details"
                  parent="surepay_payroll.menu_surepay_payroll_root"
                  action="action_hr_prorata_details"
                  sequence="71"/>

    </data>
</odoo>
