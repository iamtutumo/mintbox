<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Inherit hr.payslip form view to add Prorata information -->
        <record id="hr_payslip_view_form_inherit_prorata" model="ir.ui.view">
            <field name="name">hr.payslip.form.inherit.prorata</field>
            <field name="model">surepay_payroll.hr.payslip</field>
            <field name="inherit_id" ref="surepay_payroll.hr_payslip_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet/group" position="inside">
                    <group string="Prorata Information" invisible="is_prorata == False">
                        <field name="is_prorata" invisible="1"/>
                        <field name="prorata_days_worked" readonly="1"/>
                        <field name="prorata_total_days" readonly="1"/>
                        <field name="prorata_factor" readonly="1"/>
                        <button name="action_view_prorata_details" 
                                type="object" 
                                string="View Prorata Details" 
                                class="oe_highlight"
                                invisible="is_prorata == False"/>
                    </group>
                </xpath>
            </field>
        </record>

        <!-- Inherit hr.payslip tree view to add Prorata columns -->
        <record id="hr_payslip_view_tree_inherit_prorata" model="ir.ui.view">
            <field name="name">hr.payslip.tree.inherit.prorata</field>
            <field name="model">surepay_payroll.hr.payslip</field>
            <field name="inherit_id" ref="surepay_payroll.hr_payslip_view_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='state']" position="after">
                    <field name="is_prorata" optional="show"/>
                    <field name="prorata_factor" optional="show"/>
                </xpath>
            </field>
        </record>

        <!-- Inherit hr.payslip search view to add Prorata filters -->
        <record id="hr_payslip_view_search_inherit_prorata" model="ir.ui.view">
            <field name="name">hr.payslip.search.inherit.prorata</field>
            <field name="model">surepay_payroll.hr.payslip</field>
            <field name="inherit_id" ref="surepay_payroll.hr_payslip_search"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='done']" position="after">
                    <separator/>
                    <filter name="is_prorata" string="Is Prorata" domain="[('is_prorata', '=', True)]"/>
                    <filter name="not_prorata" string="Not Prorata" domain="[('is_prorata', '=', False)]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter name="group_prorata_status" string="Prorata Status" context="{'group_by': 'is_prorata'}"/>
                        <filter name="group_prorata_factor" string="Prorata Factor" context="{'group_by': 'prorata_factor'}"/>
                    </group>
                </xpath>
            </field>
        </record>

        <!-- Inherit hr.payslip kanban view to add Prorata badge -->
        <record id="hr_payslip_view_kanban_inherit_prorata" model="ir.ui.view">
            <field name="name">hr.payslip.kanban.inherit.prorata</field>
            <field name="model">surepay_payroll.hr.payslip</field>
            <field name="inherit_id" ref="surepay_payroll.hr_payslip_view_kanban"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']/.." position="inside">
                    <field name="is_prorata" invisible="1"/>
                    <field name="prorata_factor" invisible="1"/>
                    <div t-if="record.is_prorata.value" class="col-12 text-warning">
                        <i class="fa fa-calculator"/> Prorata: <field name="prorata_factor" widget="percent"/>
                    </div>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
